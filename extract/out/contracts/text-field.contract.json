{
  "$schema": "./contract.schema.json",
  "id": "ds.text-field",
  "name": "TextField",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/TextField/TextField.tsx (react-tsx adapter) — API surface only; anatomy, tokens, and design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "size",
      "description": "Control size scale.",
      "type": {
        "enum": [
          "sm",
          "md",
          "lg"
        ]
      },
      "default": "md",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Size",
          "values": {
            "sm": "Sm",
            "md": "Md",
            "lg": "Lg"
          }
        },
        "code": {
          "prop": "size"
        }
      }
    },
    {
      "name": "isRequired",
      "description": "Marks the field required — shows the indicator beside the label.",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Is Required"
        },
        "code": {
          "prop": "isRequired"
        }
      }
    },
    {
      "name": "isDisabled",
      "description": "Disabled state.",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Is Disabled"
        },
        "code": {
          "prop": "isDisabled"
        }
      }
    },
    {
      "name": "label",
      "description": "Field label — always rendered; placeholders are not labels.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "label"
        }
      }
    },
    {
      "name": "description",
      "description": "Helper text between the label and the input.",
      "type": "text",
      "default": "Helper text that explains the expected value.",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Description"
        },
        "code": {
          "prop": "description"
        }
      }
    },
    {
      "name": "placeholder",
      "description": "Hint shown when the field is empty. Never a substitute for the label.",
      "type": "text",
      "default": "Enter a value…",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Placeholder"
        },
        "code": {
          "prop": "placeholder"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {}
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/TextField/TextField",
      "export": "TextField"
    }
  }
}
