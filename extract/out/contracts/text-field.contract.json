{
  "$schema": "./contract.schema.json",
  "id": "ds.text-field",
  "name": "TextField",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/TextField/TextField.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "label"
  },
  "props": [
    {
      "name": "size",
      "description": "Control size scale.",
      "type": {
        "enum": [
          "sm",
          "md",
          "lg"
        ]
      },
      "default": "md",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Size",
          "values": {
            "sm": "Sm",
            "md": "Md",
            "lg": "Lg"
          }
        },
        "code": {
          "prop": "size"
        }
      }
    },
    {
      "name": "isRequired",
      "description": "Marks the field required — shows the indicator beside the label.",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Is Required"
        },
        "code": {
          "prop": "isRequired"
        }
      }
    },
    {
      "name": "isDisabled",
      "description": "Disabled state.",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Is Disabled"
        },
        "code": {
          "prop": "isDisabled"
        }
      }
    },
    {
      "name": "label",
      "description": "Field label — always rendered; placeholders are not labels.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "label"
        }
      }
    },
    {
      "name": "description",
      "description": "Helper text between the label and the input.",
      "type": "text",
      "default": "Helper text that explains the expected value.",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Description"
        },
        "code": {
          "prop": "description"
        }
      }
    },
    {
      "name": "placeholder",
      "description": "Hint shown when the field is empty. Never a substitute for the label.",
      "type": "text",
      "default": "Enter a value…",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Placeholder"
        },
        "code": {
          "prop": "placeholder"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "flex",
        "direction": "column",
        "align": "stretch"
      },
      "tokens": {
        "max-width": "{size.card.width}",
        "gap": "{space.inset-y.sm}",
        "font-family": "{font.control.family}",
        "color": "{color.surface.foreground}"
      },
      "parts": {
        "labelRow": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center"
          },
          "tokens": {
            "gap": "{space.inset-y.sm}",
            "font-size": "{font.control.size.sm}",
            "font-weight": "{font.control.weight}"
          },
          "parts": {
            "labelText": {
              "element": "span",
              "content": {
                "prop": "label"
              }
            },
            "requiredMark": {
              "element": "span",
              "layout": {
                "display": "inline-flex"
              },
              "tokens": {
                "color": "{color.action.danger.background}"
              },
              "visibleWhen": {
                "prop": "isRequired"
              }
            }
          }
        },
        "descriptionText": {
          "element": "span",
          "tokens": {
            "font-size": "{font.control.size.sm}",
            "color": "{color.text.secondary}"
          },
          "content": {
            "prop": "description"
          }
        },
        "input": {
          "element": "input",
          "tokens": {
            "background-color": "{color.input.background}",
            "border-color": "{color.border.subtle}",
            "border-width": "{border-width.100}",
            "border-radius": "{radius.control}",
            "padding-inline": "{space.inset-x.sm}",
            "font-family": "{font.control.family}",
            "color": "{color.surface.foreground}",
            "padding-block": "{space.inset-y.{size}}",
            "font-size": "{font.control.size.{size}}"
          },
          "attrs": {
            "type": "text",
            "placeholder": "{placeholder}"
          }
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/TextField/TextField",
      "export": "TextField"
    }
  }
}
