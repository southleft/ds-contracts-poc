{
  "$schema": "./contract.schema.json",
  "id": "ds.spinner",
  "name": "Spinner",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/Spinner/Spinner.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "span",
    "role": "status"
  },
  "props": [
    {
      "name": "label",
      "description": "What is loading — announced to screen readers.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "label"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "inline-flex",
        "direction": "row",
        "align": "center"
      },
      "tokens": {
        "color": "{color.action.primary.background}"
      },
      "parts": {
        "arc": {
          "element": "span",
          "layout": {
            "display": "inline-flex"
          },
          "animation": "spin"
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/Spinner/Spinner",
      "export": "Spinner"
    }
  }
}
