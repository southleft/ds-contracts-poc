{
  "$schema": "./contract.schema.json",
  "id": "ds.skeleton",
  "name": "Skeleton",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/Skeleton/Skeleton.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "span"
  },
  "props": [
    {
      "name": "variant",
      "description": "The shape being previewed.",
      "type": {
        "enum": [
          "text",
          "rect",
          "circle"
        ]
      },
      "default": "text",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Variant",
          "values": {
            "text": "Text",
            "rect": "Rect",
            "circle": "Circle"
          }
        },
        "code": {
          "prop": "variant"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "inline-flex",
        "direction": "row"
      },
      "parts": {
        "block": {
          "element": "span",
          "tokens": {
            "background-color": "{color.skeleton}",
            "width": "{size.skeleton.{variant}.width}",
            "height": "{size.skeleton.{variant}.height}",
            "border-radius": "{radius.skeleton.{variant}}"
          },
          "animation": "pulse"
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/Skeleton/Skeleton",
      "export": "Skeleton"
    }
  }
}
