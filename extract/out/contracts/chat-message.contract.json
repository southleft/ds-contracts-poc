{
  "$schema": "./contract.schema.json",
  "id": "ds.chat-message",
  "name": "ChatMessage",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/ChatMessage/ChatMessage.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "sender",
      "description": "Who sent it — drives the bubble color scheme.",
      "type": {
        "enum": [
          "user",
          "assistant",
          "system"
        ]
      },
      "default": "assistant",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Sender",
          "values": {
            "user": "User",
            "assistant": "Assistant",
            "system": "System"
          }
        },
        "code": {
          "prop": "sender"
        }
      }
    },
    {
      "name": "name",
      "description": "Sender name shown above the message body.",
      "type": "text",
      "default": "Assistant",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Name"
        },
        "code": {
          "prop": "name"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "flex",
        "direction": "row",
        "align": "start"
      },
      "tokens": {
        "max-width": "{size.banner.width}",
        "gap": "{space.gap.sm}",
        "font-family": "{font.control.family}"
      },
      "parts": {
        "avatarSlot": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "start"
          },
          "slot": {
            "name": "avatar"
          },
          "optional": true
        },
        "body": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "column",
            "align": "stretch",
            "grow": true
          },
          "tokens": {
            "gap": "{space.inset-y.sm}"
          },
          "parts": {
            "nameText": {
              "element": "span",
              "tokens": {
                "font-size": "{font.badge.size}",
                "font-weight": "{font.title.weight}",
                "color": "{color.text.secondary}"
              },
              "content": {
                "prop": "name"
              }
            },
            "bubble": {
              "element": "div",
              "layout": {
                "display": "flex",
                "direction": "column",
                "align": "stretch"
              },
              "tokens": {
                "border-radius": "{radius.card}",
                "gap": "{space.inset-y.sm}",
                "padding-inline": "{space.inset-x.sm}",
                "padding-block": "{space.inset-y.md}",
                "font-size": "{font.control.size.sm}",
                "background-color": "{color.chat.{sender}.background}",
                "color": "{color.chat.{sender}.foreground}"
              },
              "slot": {
                "name": "children"
              }
            },
            "metadataSlot": {
              "element": "div",
              "layout": {
                "display": "flex",
                "direction": "row",
                "align": "center"
              },
              "slot": {
                "name": "metadata"
              },
              "optional": true
            }
          }
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/ChatMessage/ChatMessage",
      "export": "ChatMessage"
    }
  }
}
