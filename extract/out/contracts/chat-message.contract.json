{
  "$schema": "./contract.schema.json",
  "id": "ds.chat-message",
  "name": "ChatMessage",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/ChatMessage/ChatMessage.tsx (react-tsx adapter) — API surface only; anatomy, tokens, and design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "sender",
      "description": "Who sent it — drives the bubble color scheme.",
      "type": {
        "enum": [
          "user",
          "assistant",
          "system"
        ]
      },
      "default": "assistant",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Sender",
          "values": {
            "user": "User",
            "assistant": "Assistant",
            "system": "System"
          }
        },
        "code": {
          "prop": "sender"
        }
      }
    },
    {
      "name": "name",
      "description": "Sender name shown above the message body.",
      "type": "text",
      "default": "Assistant",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Name"
        },
        "code": {
          "prop": "name"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {}
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/ChatMessage/ChatMessage",
      "export": "ChatMessage"
    }
  }
}
