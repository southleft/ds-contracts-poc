{
  "$schema": "./contract.schema.json",
  "id": "ds.banner",
  "name": "Banner",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/Banner/Banner.tsx (react-tsx adapter) — API surface only; anatomy, tokens, and design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "status",
      "description": "Feedback tone — drives the color scheme, the leading icon, and the ARIA role (error/warning announce as alerts).",
      "type": {
        "enum": [
          "info",
          "success",
          "warning",
          "error"
        ]
      },
      "default": "info",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Status",
          "values": {
            "info": "Info",
            "success": "Success",
            "warning": "Warning",
            "error": "Error"
          }
        },
        "code": {
          "prop": "status"
        }
      }
    },
    {
      "name": "container",
      "description": "card = standalone with radius; section = full-bleed, square.",
      "type": {
        "enum": [
          "card",
          "section"
        ]
      },
      "default": "card",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Container",
          "values": {
            "card": "Card",
            "section": "Section"
          }
        },
        "code": {
          "prop": "container"
        }
      }
    },
    {
      "name": "isDismissable",
      "description": "Shows the close affordance. Keep error banners until resolved.",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Is Dismissable"
        },
        "code": {
          "prop": "isDismissable"
        }
      }
    },
    {
      "name": "title",
      "description": "Prominent header text.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Title"
        },
        "code": {
          "prop": "title"
        }
      }
    },
    {
      "name": "description",
      "description": "Secondary text below the title.",
      "type": "text",
      "default": "Supporting detail that explains what happened and what to do next.",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Description"
        },
        "code": {
          "prop": "description"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {}
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/Banner/Banner",
      "export": "Banner"
    }
  }
}
