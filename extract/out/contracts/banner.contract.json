{
  "$schema": "./contract.schema.json",
  "id": "ds.banner",
  "name": "Banner",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/Banner/Banner.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "status",
      "description": "Feedback tone — drives the color scheme, the leading icon, and the ARIA role (error/warning announce as alerts).",
      "type": {
        "enum": [
          "info",
          "success",
          "warning",
          "error"
        ]
      },
      "default": "info",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Status",
          "values": {
            "info": "Info",
            "success": "Success",
            "warning": "Warning",
            "error": "Error"
          }
        },
        "code": {
          "prop": "status"
        }
      }
    },
    {
      "name": "container",
      "description": "card = standalone with radius; section = full-bleed, square.",
      "type": {
        "enum": [
          "card",
          "section"
        ]
      },
      "default": "card",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Container",
          "values": {
            "card": "Card",
            "section": "Section"
          }
        },
        "code": {
          "prop": "container"
        }
      }
    },
    {
      "name": "isDismissable",
      "description": "Shows the close affordance. Keep error banners until resolved.",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Is Dismissable"
        },
        "code": {
          "prop": "isDismissable"
        }
      }
    },
    {
      "name": "title",
      "description": "Prominent header text.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Title"
        },
        "code": {
          "prop": "title"
        }
      }
    },
    {
      "name": "description",
      "description": "Secondary text below the title.",
      "type": "text",
      "default": "Supporting detail that explains what happened and what to do next.",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Description"
        },
        "code": {
          "prop": "description"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "flex",
        "direction": "row",
        "align": "start"
      },
      "tokens": {
        "max-width": "{size.banner.width}",
        "gap": "{space.gap.control}",
        "padding-inline": "{space.inset-x.md}",
        "padding-block": "{space.inset-y.lg}",
        "background-color": "{color.feedback.{status}.background}",
        "color": "{color.feedback.{status}.foreground}",
        "border-radius": "{radius.banner.{container}}"
      },
      "parts": {
        "statusIcon": {
          "element": "span",
          "layout": {
            "display": "inline-flex"
          }
        },
        "body": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "column",
            "grow": true
          },
          "tokens": {
            "gap": "{space.inset-y.sm}"
          },
          "parts": {
            "title": {
              "element": "div",
              "tokens": {
                "font-family": "{font.control.family}",
                "font-size": "{font.control.size.md}",
                "font-weight": "{font.title.weight}"
              },
              "content": {
                "prop": "title"
              }
            },
            "descriptionText": {
              "element": "div",
              "tokens": {
                "font-family": "{font.control.family}",
                "font-size": "{font.control.size.sm}"
              },
              "content": {
                "prop": "description"
              }
            }
          }
        },
        "endArea": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center"
          },
          "tokens": {
            "gap": "{space.gap.sm}"
          },
          "parts": {
            "endContent": {
              "element": "div",
              "layout": {
                "display": "flex",
                "direction": "row",
                "align": "center"
              },
              "slot": {
                "name": "endContent"
              },
              "optional": true
            },
            "close": {
              "element": "button",
              "layout": {
                "display": "inline-flex",
                "align": "center",
                "justify": "center"
              },
              "attrs": {
                "aria-label": "Dismiss",
                "type": "button",
                "data-action": "dismiss"
              },
              "visibleWhen": {
                "prop": "isDismissable"
              },
              "parts": {
                "closeGlyph": {
                  "element": "span",
                  "layout": {
                    "display": "inline-flex"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/Banner/Banner",
      "export": "Banner"
    }
  }
}
