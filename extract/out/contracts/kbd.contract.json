{
  "$schema": "./contract.schema.json",
  "id": "ds.kbd",
  "name": "Kbd",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/Kbd/Kbd.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "kbd"
  },
  "props": [
    {
      "name": "keys",
      "description": "The shortcut text, e.g. \"⌘K\".",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Keys"
        },
        "code": {
          "prop": "keys"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "inline-flex",
        "direction": "row",
        "align": "center",
        "justify": "center"
      },
      "tokens": {
        "background-color": "{color.surface.sunken}",
        "color": "{color.surface.foreground}",
        "border-color": "{color.border.subtle}",
        "border-width": "{border-width.100}",
        "border-radius": "{radius.100}",
        "padding-inline": "{space.inset-x.xs}",
        "padding-block": "{space.inset-y.xs}",
        "font-family": "{font.code.family}",
        "font-size": "{font.badge.size}"
      },
      "parts": {
        "keysText": {
          "element": "span",
          "content": {
            "prop": "keys"
          }
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/Kbd/Kbd",
      "export": "Kbd"
    }
  }
}
