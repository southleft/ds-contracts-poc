{
  "$schema": "./contract.schema.json",
  "id": "ds.progress-bar",
  "name": "ProgressBar",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/ProgressBar/ProgressBar.tsx (react-tsx adapter) — API surface only; anatomy, tokens, and design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "variant",
      "description": "Semantic color of the fill.",
      "type": {
        "enum": [
          "accent",
          "success",
          "warning",
          "error",
          "neutral"
        ]
      },
      "default": "accent",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Variant",
          "values": {
            "accent": "Accent",
            "success": "Success",
            "warning": "Warning",
            "error": "Error",
            "neutral": "Neutral"
          }
        },
        "code": {
          "prop": "variant"
        }
      }
    },
    {
      "name": "value",
      "description": "Current progress value.",
      "type": "number",
      "default": 60,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Value"
        },
        "code": {
          "prop": "value"
        }
      }
    },
    {
      "name": "max",
      "description": "Maximum value.",
      "type": "number",
      "default": 100,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Max"
        },
        "code": {
          "prop": "max"
        }
      }
    },
    {
      "name": "label",
      "description": "Accessible name — screen readers must know what is progressing.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "label"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {}
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/ProgressBar/ProgressBar",
      "export": "ProgressBar"
    }
  }
}
