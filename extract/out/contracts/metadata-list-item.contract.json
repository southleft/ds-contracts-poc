{
  "$schema": "./contract.schema.json",
  "id": "ds.metadata-list-item",
  "name": "MetadataListItem",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/MetadataListItem/MetadataListItem.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "label",
      "description": "The key text.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "label"
        }
      }
    },
    {
      "name": "value",
      "description": "The value text. Use the children slot instead for rich values.",
      "type": "text",
      "default": "Value",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Value"
        },
        "code": {
          "prop": "value"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "flex",
        "direction": "row",
        "align": "start"
      },
      "tokens": {
        "gap": "{space.gap.md}",
        "font-family": "{font.control.family}",
        "font-size": "{font.control.size.sm}"
      },
      "parts": {
        "iconSlot": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center"
          },
          "slot": {
            "name": "icon"
          },
          "optional": true
        },
        "labelText": {
          "element": "span",
          "tokens": {
            "color": "{color.text.secondary}",
            "min-width": "{container.xs}"
          },
          "content": {
            "prop": "label"
          }
        },
        "valueText": {
          "element": "span",
          "layout": {
            "grow": true
          },
          "tokens": {
            "color": "{color.surface.foreground}",
            "font-weight": "{font.control.weight}"
          },
          "content": {
            "prop": "value"
          }
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/MetadataListItem/MetadataListItem",
      "export": "MetadataListItem"
    }
  }
}
