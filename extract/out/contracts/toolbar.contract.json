{
  "$schema": "./contract.schema.json",
  "id": "ds.toolbar",
  "name": "Toolbar",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/Toolbar/Toolbar.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div",
    "role": "toolbar"
  },
  "props": [
    {
      "name": "size",
      "description": "Minimum toolbar height; children keep their own sizes.",
      "type": {
        "enum": [
          "sm",
          "md",
          "lg"
        ]
      },
      "default": "md",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Size",
          "values": {
            "sm": "Sm",
            "md": "Md",
            "lg": "Lg"
          }
        },
        "code": {
          "prop": "size"
        }
      }
    },
    {
      "name": "label",
      "description": "Accessible label for the toolbar.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "label"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "flex",
        "direction": "row",
        "align": "center",
        "justify": "space-between"
      },
      "tokens": {
        "max-width": "{size.banner.width}",
        "background-color": "{color.surface.raised}",
        "border-color": "{color.border.subtle}",
        "border-width": "{border-width.100}",
        "border-radius": "{radius.control}",
        "gap": "{space.gap.md}",
        "padding-inline": "{space.inset-x.sm}",
        "padding-block": "{space.inset-y.sm}",
        "min-height": "{size.toolbar.{size}}"
      },
      "parts": {
        "startContent": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center"
          },
          "tokens": {
            "gap": "{space.gap.sm}"
          },
          "slot": {
            "name": "startContent"
          },
          "optional": true
        },
        "centerContent": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center"
          },
          "tokens": {
            "gap": "{space.gap.sm}"
          },
          "slot": {
            "name": "centerContent"
          },
          "optional": true
        },
        "endContent": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center"
          },
          "tokens": {
            "gap": "{space.gap.sm}"
          },
          "slot": {
            "name": "endContent"
          },
          "optional": true
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/Toolbar/Toolbar",
      "export": "Toolbar"
    }
  }
}
