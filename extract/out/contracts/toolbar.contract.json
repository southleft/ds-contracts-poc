{
  "$schema": "./contract.schema.json",
  "id": "ds.toolbar",
  "name": "Toolbar",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/Toolbar/Toolbar.tsx (react-tsx adapter) — API surface only; anatomy, tokens, and design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "size",
      "description": "Minimum toolbar height; children keep their own sizes.",
      "type": {
        "enum": [
          "sm",
          "md",
          "lg"
        ]
      },
      "default": "md",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Size",
          "values": {
            "sm": "Sm",
            "md": "Md",
            "lg": "Lg"
          }
        },
        "code": {
          "prop": "size"
        }
      }
    },
    {
      "name": "label",
      "description": "Accessible label for the toolbar.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "label"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {}
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/Toolbar/Toolbar",
      "export": "Toolbar"
    }
  }
}
