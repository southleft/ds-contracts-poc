{
  "$schema": "./contract.schema.json",
  "id": "ds.table",
  "name": "Table",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/Table/Table.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div",
    "role": "table"
  },
  "props": [
    {
      "name": "density",
      "description": "Vertical rhythm of the whole table; mapped into the fixed header cells.",
      "type": {
        "enum": [
          "comfortable",
          "compact"
        ]
      },
      "default": "comfortable",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Density",
          "values": {
            "comfortable": "Comfortable",
            "compact": "Compact"
          }
        },
        "code": {
          "prop": "density"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "flex",
        "direction": "column",
        "align": "stretch"
      },
      "tokens": {
        "background-color": "{color.surface.raised}",
        "border-color": "{color.border.subtle}",
        "border-width": "{border-width.100}",
        "border-radius": "{radius.card}",
        "max-width": "{size.table.width}"
      },
      "parts": {
        "header": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center"
          },
          "tokens": {
            "background-color": "{color.surface.sunken}"
          },
          "parts": {
            "tableHeaderCell": {
              "component": {
                "id": "ds.table-header-cell",
                "props": {
                  "density": "{density}"
                },
                "text": "Name"
              }
            },
            "tableHeaderCell2": {
              "component": {
                "id": "ds.table-header-cell",
                "props": {
                  "density": "{density}"
                },
                "text": "Role"
              }
            },
            "tableHeaderCell3": {
              "component": {
                "id": "ds.table-header-cell",
                "props": {
                  "density": "{density}"
                },
                "text": "Status"
              }
            }
          }
        },
        "body": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "column",
            "align": "stretch"
          },
          "slot": {
            "name": "children"
          }
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/Table/Table",
      "export": "Table"
    }
  }
}
