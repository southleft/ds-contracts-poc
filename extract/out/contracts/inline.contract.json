{
  "$schema": "./contract.schema.json",
  "id": "ds.inline",
  "name": "Inline",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/Inline/Inline.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "gap",
      "description": "Space between children.",
      "type": {
        "enum": [
          "sm",
          "md",
          "lg"
        ]
      },
      "default": "md",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Gap",
          "values": {
            "sm": "Sm",
            "md": "Md",
            "lg": "Lg"
          }
        },
        "code": {
          "prop": "gap"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "flex",
        "direction": "row",
        "align": "center"
      },
      "tokens": {
        "gap": "{space.gap.{gap}}"
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/Inline/Inline",
      "export": "Inline"
    }
  }
}
