{
  "$schema": "./contract.schema.json",
  "id": "ds.icon-button",
  "name": "IconButton",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/IconButton/IconButton.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "button"
  },
  "props": [
    {
      "name": "variant",
      "description": "Visual style. Ghost sits on the surface wash (transparent tokens are a documented gap).",
      "type": {
        "enum": [
          "primary",
          "secondary",
          "ghost",
          "destructive"
        ]
      },
      "default": "secondary",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Variant",
          "values": {
            "primary": "Primary",
            "secondary": "Secondary",
            "ghost": "Ghost",
            "destructive": "Destructive"
          }
        },
        "code": {
          "prop": "variant"
        }
      }
    },
    {
      "name": "size",
      "description": "Square control size.",
      "type": {
        "enum": [
          "sm",
          "md",
          "lg"
        ]
      },
      "default": "md",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Size",
          "values": {
            "sm": "Sm",
            "md": "Md",
            "lg": "Lg"
          }
        },
        "code": {
          "prop": "size"
        }
      }
    },
    {
      "name": "isDisabled",
      "description": "Disables the button.",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Is Disabled"
        },
        "code": {
          "prop": "isDisabled"
        }
      }
    },
    {
      "name": "label",
      "description": "Accessible name (aria-label). Be specific: \"Delete conversation\", not \"Delete\".",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "label"
        }
      }
    }
  ],
  "states": [
    "hover",
    "focus-visible"
  ],
  "anatomy": {
    "root": {
      "layout": {
        "display": "inline-flex",
        "direction": "row",
        "align": "center",
        "justify": "center"
      },
      "tokens": {
        "border-radius": "{radius.control}",
        "width": "{size.icon-button.{size}}",
        "height": "{size.icon-button.{size}}",
        "background-color": "{color.action.{variant}.background}",
        "color": "{color.action.{variant}.foreground}"
      },
      "states": {
        "focus-visible": {
          "outline-color": "{color.border.focus}",
          "outline-width": "{border.width.focus}"
        },
        "hover": {
          "background-color": "{color.action.{variant}.background-hover}"
        }
      },
      "parts": {
        "iconSlot": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center",
            "justify": "center"
          },
          "slot": {
            "name": "icon"
          }
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/IconButton/IconButton",
      "export": "IconButton"
    }
  }
}
