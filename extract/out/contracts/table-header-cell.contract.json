        "figma": {
          "kind": "VARIANT",
          "property": "Density",
          "values": {
            "comfortable": "Comfortable",
            "compact": "Compact"
          }
        },
        "code": {
          "prop": "density"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "flex",
        "direction": "row",
        "align": "center"
      },
      "tokens": {
        "padding-inline": "{space.inset-x.sm}",
        "color": "{color.surface.foreground}",
        "font-family": "{font.control.family}",
        "font-size": "{font.control.size.sm}",
        "font-weight": "{font.title.weight}",
        "min-width": "{size.table.cell-width}",
        "padding-block": "{space.table.cell-y.{density}}"
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/TableHeaderCell/TableHeaderCell",
      "export": "TableHeaderCell"
    }
  }
