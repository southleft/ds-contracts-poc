{
  "$schema": "./contract.schema.json",
  "id": "ds.table-header-cell",
  "name": "TableHeaderCell",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/TableHeaderCell/TableHeaderCell.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div",
    "role": "columnheader"
  },
  "props": [
