{
  "$schema": "./contract.schema.json",
  "id": "ds.metadata-list",
  "name": "MetadataList",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/MetadataList/MetadataList.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "title",
      "description": "Heading above the list.",
      "type": "text",
      "default": "Details",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Title"
        },
        "code": {
          "prop": "title"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "flex",
        "direction": "column",
        "align": "stretch"
      },
      "tokens": {
        "max-width": "{size.card.width}",
        "gap": "{space.gap.sm}",
        "font-family": "{font.control.family}"
      },
      "parts": {
        "titleText": {
          "element": "span",
          "tokens": {
            "font-size": "{font.control.size.sm}",
            "font-weight": "{font.title.weight}",
            "color": "{color.surface.foreground}"
          },
          "content": {
            "prop": "title"
          }
        },
        "items": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "column",
            "align": "stretch"
          },
          "tokens": {
            "gap": "{space.gap.sm}"
          },
          "slot": {
            "name": "children"
          }
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/MetadataList/MetadataList",
      "export": "MetadataList"
    }
  }
}
