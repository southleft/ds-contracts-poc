{
  "$schema": "./contract.schema.json",
  "id": "ds.divider",
  "name": "Divider",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/Divider/Divider.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "hr",
    "role": "separator"
  },
  "props": [
    {
      "name": "variant",
      "description": "Visual weight of the line.",
      "type": {
        "enum": [
          "subtle",
          "strong"
        ]
      },
      "default": "subtle",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Variant",
          "values": {
            "subtle": "Subtle",
            "strong": "Strong"
          }
        },
        "code": {
          "prop": "variant"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "inline-flex",
        "align": "center",
        "justify": "center"
      },
      "tokens": {
        "max-width": "{size.divider.length}",
        "background-color": "{color.divider.{variant}}",
        "height": "{border.width.divider.{variant}}"
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/Divider/Divider",
      "export": "Divider"
    }
  }
}
