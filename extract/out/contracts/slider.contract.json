{
  "$schema": "./contract.schema.json",
  "id": "ds.slider",
  "name": "Slider",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/Slider/Slider.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "value",
      "description": "Current value — positions the thumb.",
      "type": "number",
      "default": 40,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Value"
        },
        "code": {
          "prop": "value"
        }
      }
    },
    {
      "name": "max",
      "description": "Maximum value.",
      "type": "number",
      "default": 100,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Max"
        },
        "code": {
          "prop": "max"
        }
      }
    },
    {
      "name": "label",
      "description": "Always rendered.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "label"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "flex",
        "direction": "column"
      },
      "tokens": {
        "max-width": "{size.slider.width}",
        "gap": "{space.inset-y.sm}",
        "font-family": "{font.control.family}",
        "color": "{color.surface.foreground}"
      },
      "parts": {
        "labelText": {
          "element": "span",
          "tokens": {
            "font-size": "{font.control.size.sm}",
            "font-weight": "{font.control.weight}"
          },
          "content": {
            "prop": "label"
          }
        },
        "trackRow": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center"
          },
          "tokens": {
            "width": "{size.slider.width}"
          },
          "parts": {
            "filled": {
              "element": "div",
              "tokens": {
                "height": "{size.slider.track}",
                "background-color": "{color.progress.accent}",
                "border-radius": "{radius.100}"
              }
            },
            "thumb": {
              "element": "span",
              "tokens": {
                "width": "{size.slider.thumb}",
                "height": "{size.slider.thumb}",
                "background-color": "{color.switch.thumb}",
                "border-color": "{color.progress.accent}",
                "border-width": "{border-width.200}",
                "border-radius": "{radius.pill}"
              }
            },
            "remainder": {
              "element": "div",
              "layout": {
                "display": "flex",
                "grow": true
              },
              "tokens": {
                "height": "{size.slider.track}",
                "background-color": "{color.progress.track}",
                "border-radius": "{radius.100}"
              }
            }
          }
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/Slider/Slider",
      "export": "Slider"
    }
  }
}
