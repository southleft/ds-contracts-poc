{
  "$schema": "./contract.schema.json",
  "id": "ds.tab",
  "name": "Tab",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/Tab/Tab.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "button",
    "role": "tab"
  },
  "props": [
    {
      "name": "state",
      "description": "Selection state — selected tabs render semibold in the accent color.",
      "type": {
        "enum": [
          "default",
          "selected"
        ]
      },
      "default": "default",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "State",
          "values": {
            "default": "Default",
            "selected": "Selected"
          }
        },
        "code": {
          "prop": "state"
        }
      }
    },
    {
      "name": "label",
      "description": "Visible tab text.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "label"
        }
      }
    }
  ],
  "states": [
    "hover"
  ],
  "anatomy": {
    "root": {
      "layout": {
        "display": "inline-flex",
        "direction": "row",
        "align": "center"
      },
      "tokens": {
        "background-color": "{color.surface.background}",
        "font-family": "{font.control.family}",
        "font-size": "{font.control.size.sm}",
        "gap": "{space.inset-y.sm}",
        "padding-inline": "{space.inset-x.sm}",
        "padding-block": "{space.inset-y.md}",
        "border-radius": "{radius.100}",
        "color": "{color.tab.{state}.foreground}",
        "font-weight": "{font.tab.{state}.weight}"
      },
      "states": {
        "hover": {
          "background-color": "{color.surface.sunken}"
        }
      },
      "parts": {
        "iconSlot": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center"
          },
          "slot": {
            "name": "icon"
          },
          "optional": true
        },
        "labelText": {
          "element": "span",
          "content": {
            "prop": "label"
          }
        },
        "endContent": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center"
          },
          "slot": {
            "name": "endContent"
          },
          "optional": true
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/Tab/Tab",
      "export": "Tab"
    }
  }
}
