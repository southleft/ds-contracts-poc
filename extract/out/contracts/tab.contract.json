{
  "$schema": "./contract.schema.json",
  "id": "ds.tab",
  "name": "Tab",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/Tab/Tab.tsx (react-tsx adapter) — API surface only; anatomy, tokens, and design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "state",
      "description": "Selection state — selected tabs render semibold in the accent color.",
      "type": {
        "enum": [
          "default",
          "selected"
        ]
      },
      "default": "default",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "State",
          "values": {
            "default": "Default",
            "selected": "Selected"
          }
        },
        "code": {
          "prop": "state"
        }
      }
    },
    {
      "name": "label",
      "description": "Visible tab text.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "label"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {}
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/Tab/Tab",
      "export": "Tab"
    }
  }
}
