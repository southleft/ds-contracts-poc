{
  "$schema": "./contract.schema.json",
  "id": "ds.checkbox",
  "name": "Checkbox",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/Checkbox/Checkbox.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "label"
  },
  "props": [
    {
      "name": "value",
      "description": "Checked, unchecked, or indeterminate (partial selection in a group).",
      "type": {
        "enum": [
          "unchecked",
          "checked",
          "indeterminate"
        ]
      },
      "default": "unchecked",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Value",
          "values": {
            "unchecked": "Unchecked",
            "checked": "Checked",
            "indeterminate": "Indeterminate"
          }
        },
        "code": {
          "prop": "value"
        }
      }
    },
    {
      "name": "size",
      "description": "Control size.",
      "type": {
        "enum": [
          "sm",
          "md"
        ]
      },
      "default": "md",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Size",
          "values": {
            "sm": "Sm",
            "md": "Md"
          }
        },
        "code": {
          "prop": "size"
        }
      }
    },
    {
      "name": "label",
      "description": "Always rendered — users must know what they are toggling.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "label"
        }
      }
    },
    {
      "name": "description",
      "description": "Secondary text below the label.",
      "type": "text",
      "default": "Supporting detail for this option.",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Description"
        },
        "code": {
          "prop": "description"
        }
      }
    }
  ],
  "events": [
    {
      "name": "toggle",
      "description": "Fires when the input is toggled; uncontrolled instances flip unchecked/checked (indeterminate resolves to checked).",
      "bindings": {
        "code": {
          "prop": "onToggle"
        }
      },
      "trigger": "input",
      "toggles": {
        "prop": "value",
        "between": [
          "unchecked",
          "checked"
        ],
        "aria": "checked"
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "flex",
        "direction": "row",
        "align": "start"
      },
      "tokens": {
        "gap": "{space.gap.sm}",
        "font-family": "{font.control.family}",
        "color": "{color.surface.foreground}"
      },
      "parts": {
        "box": {
          "element": "span",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center",
            "justify": "center"
          },
          "tokens": {
            "border-width": "{border-width.100}",
            "border-radius": "{radius.100}",
            "color": "{color.checkbox.icon}",
            "width": "{size.checkbox.{size}}",
            "height": "{size.checkbox.{size}}",
            "background-color": "{color.checkbox.{value}.background}",
            "border-color": "{color.checkbox.{value}.border}"
          },
          "parts": {
            "input": {
              "element": "input",
              "attrs": {
                "type": "checkbox"
              }
            },
            "checkGlyph": {
              "element": "span",
              "layout": {
                "display": "inline-flex"
              },
              "visibleWhen": {
                "prop": "value",
                "equals": "checked"
              }
            },
            "dashGlyph": {
              "element": "span",
              "layout": {
                "display": "inline-flex"
              },
              "visibleWhen": {
                "prop": "value",
                "equals": "indeterminate"
              }
            }
          }
        },
        "textCol": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "column",
            "grow": true
          },
          "tokens": {
            "gap": "{space.inset-y.xs}"
          },
          "parts": {
            "labelText": {
              "element": "span",
              "tokens": {
                "font-size": "{font.control.size.sm}",
                "font-weight": "{font.control.weight}"
              },
              "content": {
                "prop": "label"
              }
            },
            "descriptionText": {
              "element": "span",
              "tokens": {
                "font-size": "{font.control.size.sm}",
                "color": "{color.text.secondary}"
              },
              "content": {
                "prop": "description"
              }
            }
          }
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/Checkbox/Checkbox",
      "export": "Checkbox"
    }
  }
}
