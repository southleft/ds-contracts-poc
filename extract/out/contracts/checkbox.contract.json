{
  "$schema": "./contract.schema.json",
  "id": "ds.checkbox",
  "name": "Checkbox",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/Checkbox/Checkbox.tsx (react-tsx adapter) — API surface only; anatomy, tokens, and design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "value",
      "description": "Checked, unchecked, or indeterminate (partial selection in a group).",
      "type": {
        "enum": [
          "unchecked",
          "checked",
          "indeterminate"
        ]
      },
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Value",
          "values": {
            "unchecked": "Unchecked",
            "checked": "Checked",
            "indeterminate": "Indeterminate"
          }
        },
        "code": {
          "prop": "value"
        }
      }
    },
    {
      "name": "size",
      "description": "Control size.",
      "type": {
        "enum": [
          "sm",
          "md"
        ]
      },
      "default": "md",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Size",
          "values": {
            "sm": "Sm",
            "md": "Md"
          }
        },
        "code": {
          "prop": "size"
        }
      }
    },
    {
      "name": "label",
      "description": "Always rendered — users must know what they are toggling.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "label"
        }
      }
    },
    {
      "name": "description",
      "description": "Secondary text below the label.",
      "type": "text",
      "default": "Supporting detail for this option.",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Description"
        },
        "code": {
          "prop": "description"
        }
      }
    }
  ],
  "events": [
    {
      "name": "toggle",
      "description": "Fires when the box is activated; uncontrolled instances flip unchecked/checked (indeterminate resolves to checked).",
      "bindings": {
        "code": {
          "prop": "onToggle"
        }
      },
      "trigger": "root"
    }
  ],
  "states": [],
  "anatomy": {
    "root": {}
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/Checkbox/Checkbox",
      "export": "Checkbox"
    }
  }
}
