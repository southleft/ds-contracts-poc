{
  "$schema": "./contract.schema.json",
  "id": "ds.chat-message-metadata",
  "name": "ChatMessageMetadata",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/ChatMessageMetadata/ChatMessageMetadata.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "status",
      "description": "Delivery status — drives the leading icon.",
      "type": {
        "enum": [
          "sending",
          "sent",
          "delivered",
          "read",
          "error"
        ]
      },
      "default": "sent",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Status",
          "values": {
            "sending": "Sending",
            "sent": "Sent",
            "delivered": "Delivered",
            "read": "Read",
            "error": "Error"
          }
        },
        "code": {
          "prop": "status"
        }
      }
    },
    {
      "name": "timestamp",
      "description": "Display timestamp text.",
      "type": "text",
      "default": "2:14 PM",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Timestamp"
        },
        "code": {
          "prop": "timestamp"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "flex",
        "direction": "row",
        "align": "center"
      },
      "tokens": {
        "gap": "{space.inset-y.sm}",
        "font-family": "{font.control.family}",
        "font-size": "{font.badge.size}",
        "color": "{color.text.secondary}"
      },
      "parts": {
        "statusIcon": {
          "element": "span",
          "layout": {
            "display": "inline-flex"
          }
        },
        "timestampText": {
          "element": "span",
          "content": {
            "prop": "timestamp"
          }
        },
        "footer": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center"
          },
          "tokens": {
            "gap": "{space.inset-y.sm}"
          },
          "slot": {
            "name": "footer"
          },
          "optional": true
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/ChatMessageMetadata/ChatMessageMetadata",
      "export": "ChatMessageMetadata"
    }
  }
}
