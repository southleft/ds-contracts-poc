{
  "$schema": "./contract.schema.json",
  "id": "ds.field",
  "name": "Field",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/Field/Field.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "isRequired",
      "description": "Shows the required indicator beside the label.",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Is Required"
        },
        "code": {
          "prop": "isRequired"
        }
      }
    },
    {
      "name": "label",
      "description": "Always rendered — even custom controls need names.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "label"
        }
      }
    },
    {
      "name": "inputID",
      "description": "The wrapped control's id, used for the label's htmlFor association.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Input ID"
        },
        "code": {
          "prop": "inputID"
        }
      }
    },
    {
      "name": "description",
      "description": "Helper text between the label and the control.",
      "type": "text",
      "default": "Helper text for the wrapped control.",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Description"
        },
        "code": {
          "prop": "description"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "flex",
        "direction": "column",
        "align": "stretch"
      },
      "tokens": {
        "max-width": "{size.card.width}",
        "gap": "{space.inset-y.sm}",
        "font-family": "{font.control.family}",
        "color": "{color.surface.foreground}"
      },
      "parts": {
        "labelRow": {
          "element": "label",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center"
          },
          "tokens": {
            "gap": "{space.inset-y.sm}",
            "font-size": "{font.control.size.sm}",
            "font-weight": "{font.control.weight}"
          },
          "attrs": {
            "htmlFor": "{inputID}"
          },
          "parts": {
            "labelText": {
              "element": "span",
              "content": {
                "prop": "label"
              }
            },
            "requiredMark": {
              "element": "span",
              "layout": {
                "display": "inline-flex"
              },
              "tokens": {
                "color": "{color.action.danger.background}"
              },
              "visibleWhen": {
                "prop": "isRequired"
              }
            }
          }
        },
        "descriptionText": {
          "element": "span",
          "tokens": {
            "font-size": "{font.control.size.sm}",
            "color": "{color.text.secondary}"
          },
          "content": {
            "prop": "description"
          }
        },
        "control": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "column",
            "align": "stretch"
          },
          "slot": {
            "name": "children"
          }
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/Field/Field",
      "export": "Field"
    }
  }
}
