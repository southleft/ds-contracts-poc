{
  "$schema": "./contract.schema.json",
  "id": "ds.avatar-group",
  "name": "AvatarGroup",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/AvatarGroup/AvatarGroup.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "overflowLabel",
      "description": "The +N overflow indicator text.",
      "type": "text",
      "default": "+3",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Overflow Label"
        },
        "code": {
          "prop": "overflowLabel"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "inline-flex",
        "direction": "row",
        "align": "center"
      },
      "tokens": {
        "gap": "{space.gap.sm}"
      },
      "parts": {
        "stack": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center",
            "overlap": true
          },
          "tokens": {
            "gap": "{space.avatarGroup.overlap}"
          },
          "slot": {
            "name": "children"
          }
        },
        "overflowText": {
          "element": "span",
          "tokens": {
            "width": "{size.avatar.md}",
            "height": "{size.avatar.md}",
            "background-color": "{color.action.secondary.background}",
            "color": "{color.text.secondary}",
            "border-radius": "{radius.pill}",
            "font-family": "{font.control.family}",
            "font-size": "{font.avatar.size.md}",
            "font-weight": "{font.control.weight}"
          },
          "content": {
            "prop": "overflowLabel"
          }
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/AvatarGroup/AvatarGroup",
      "export": "AvatarGroup"
    }
  }
}
