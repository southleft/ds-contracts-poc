{
  "$schema": "./contract.schema.json",
  "id": "ds.button",
  "name": "Button",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/Button/Button.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "button"
  },
  "props": [
    {
      "name": "variant",
      "description": "Visual prominence of the action.",
      "type": {
        "enum": [
          "primary",
          "secondary",
          "danger",
          "ghost"
        ]
      },
      "default": "primary",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Variant",
          "values": {
            "primary": "Primary",
            "secondary": "Secondary",
            "danger": "Danger",
            "ghost": "Ghost"
          }
        },
        "code": {
          "prop": "variant"
        }
      }
    },
    {
      "name": "size",
      "description": "Control density.",
      "type": {
        "enum": [
          "sm",
          "md",
          "lg"
        ]
      },
      "default": "md",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Size",
          "values": {
            "sm": "Sm",
            "md": "Md",
            "lg": "Lg"
          }
        },
        "code": {
          "prop": "size"
        }
      }
    },
    {
      "name": "disabled",
      "description": "Prevents interaction and communicates unavailability.",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Disabled"
        },
        "code": {
          "prop": "disabled"
        }
      }
    },
    {
      "name": "loading",
      "description": "Shows a spinning busy indicator beside the label while an async action resolves.",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Loading"
        },
        "code": {
          "prop": "loading"
        }
      }
    }
  ],
  "states": [
    "hover",
    "focus-visible",
    "disabled"
  ],
  "anatomy": {
    "root": {
      "layout": {
        "display": "inline-flex",
        "direction": "row",
        "align": "center",
        "justify": "center"
      },
      "tokens": {
        "border-radius": "{radius.control}",
        "gap": "{space.gap.control}",
        "font-family": "{font.control.family}",
        "font-weight": "{font.control.weight}",
        "background-color": "{color.action.{variant}.background}",
        "color": "{color.action.{variant}.foreground}",
        "padding-inline": "{space.inset-x.{size}}",
        "padding-block": "{space.inset-y.{size}}",
        "font-size": "{font.control.size.{size}}"
      },
      "states": {
        "focus-visible": {
          "outline-color": "{color.border.focus}",
          "outline-width": "{border.width.focus}"
        },
        "disabled": {
          "opacity": "{opacity.disabled}"
        },
        "hover": {
          "background-color": "{color.action.{variant}.background-hover}"
        }
      },
      "parts": {
        "loadingSpinner": {
          "element": "span",
          "layout": {
            "display": "inline-flex"
          },
          "animation": "spin",
          "visibleWhen": {
            "prop": "loading"
          }
        },
        "label": {
          "element": "span",
          "slot": {
            "name": "children"
          }
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/Button/Button",
      "export": "Button"
    }
  }
}
