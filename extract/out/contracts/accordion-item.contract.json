{
  "$schema": "./contract.schema.json",
  "id": "ds.accordion-item",
  "name": "AccordionItem",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/AccordionItem/AccordionItem.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "state",
      "description": "Closed shows only the trigger; open reveals the content and rotates the chevron.",
      "type": {
        "enum": [
          "closed",
          "open"
        ]
      },
      "default": "closed",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "State",
          "values": {
            "closed": "Closed",
            "open": "Open"
          }
        },
        "code": {
          "prop": "state"
        }
      }
    },
    {
      "name": "title",
      "description": "The always-visible trigger text.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Title"
        },
        "code": {
          "prop": "title"
        }
      }
    }
  ],
  "events": [
    {
      "name": "toggle",
      "description": "Fires when the trigger is activated; uncontrolled instances flip state closed/open themselves.",
      "bindings": {
        "code": {
          "prop": "onToggle"
        }
      },
      "trigger": "trigger",
      "toggles": {
        "prop": "state",
        "between": [
          "closed",
          "open"
        ],
        "aria": "expanded"
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "flex",
        "direction": "column",
        "align": "stretch"
      },
      "tokens": {
        "max-width": "{size.card.width}",
        "border-color": "{color.border.subtle}",
        "border-width": "{border-width.100}",
        "border-radius": "{radius.card}",
        "background-color": "{color.surface.raised}",
        "font-family": "{font.control.family}",
        "color": "{color.surface.foreground}"
      },
      "parts": {
        "trigger": {
          "element": "button",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center"
          },
          "tokens": {
            "gap": "{space.gap.sm}",
            "padding-inline": "{space.inset-x.sm}",
            "padding-block": "{space.inset-y.md}"
          },
          "parts": {
            "chevron": {
              "element": "span",
              "layout": {
                "display": "inline-flex"
              },
              "tokens": {
                "color": "{color.text.secondary}"
              }
            },
            "titleText": {
              "element": "span",
              "layout": {
                "grow": true
              },
              "tokens": {
                "font-size": "{font.control.size.sm}",
                "font-weight": "{font.control.weight}"
              },
              "content": {
                "prop": "title"
              }
            }
          }
        },
        "contentArea": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "column",
            "align": "stretch"
          },
          "tokens": {
            "padding-inline": "{space.inset-x.sm}",
            "padding-block": "{space.inset-y.md}",
            "font-size": "{font.control.size.sm}",
            "color": "{color.text.secondary}"
          },
          "slot": {
            "name": "children"
          },
          "visibleWhen": {
            "prop": "state",
            "equals": "open"
          }
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/AccordionItem/AccordionItem",
      "export": "AccordionItem"
    }
  }
}
