{
  "$schema": "./contract.schema.json",
  "id": "ds.accordion-item",
  "name": "AccordionItem",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/AccordionItem/AccordionItem.tsx (react-tsx adapter) — API surface only; anatomy, tokens, and design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "state",
      "description": "Closed shows only the trigger; open reveals the content and rotates the chevron.",
      "type": {
        "enum": [
          "closed",
          "open"
        ]
      },
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "State",
          "values": {
            "closed": "Closed",
            "open": "Open"
          }
        },
        "code": {
          "prop": "state"
        }
      }
    },
    {
      "name": "title",
      "description": "The always-visible trigger text.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Title"
        },
        "code": {
          "prop": "title"
        }
      }
    }
  ],
  "events": [
    {
      "name": "toggle",
      "description": "Fires when the trigger is activated; uncontrolled instances flip state closed/open themselves.",
      "bindings": {
        "code": {
          "prop": "onToggle"
        }
      },
      "trigger": "root"
    }
  ],
  "states": [],
  "anatomy": {
    "root": {}
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/AccordionItem/AccordionItem",
      "export": "AccordionItem"
    }
  }
}
