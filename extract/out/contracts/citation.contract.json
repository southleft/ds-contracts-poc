{
  "$schema": "./contract.schema.json",
  "id": "ds.citation",
  "name": "Citation",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/Citation/Citation.tsx (react-tsx adapter) — API surface only; anatomy, tokens, and design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "variant",
      "description": "Label chip with the source title, or a compact numbered badge. Don't mix both in one paragraph.",
      "type": {
        "enum": [
          "label",
          "number"
        ]
      },
      "default": "label",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Variant",
          "values": {
            "label": "Label",
            "number": "Number"
          }
        },
        "code": {
          "prop": "variant"
        }
      }
    },
    {
      "name": "sourceTitle",
      "description": "The source's display title (label variant).",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Source Title"
        },
        "code": {
          "prop": "sourceTitle"
        }
      }
    },
    {
      "name": "number",
      "description": "Display index (number variant).",
      "type": "text",
      "default": "1",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Number"
        },
        "code": {
          "prop": "number"
        }
      }
    },
    {
      "name": "href",
      "description": "Source URL.",
      "type": "text",
      "default": "https://example.com",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Href"
        },
        "code": {
          "prop": "href"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {}
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/Citation/Citation",
      "export": "Citation"
    }
  }
}
