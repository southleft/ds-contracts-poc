{
  "$schema": "./contract.schema.json",
  "id": "ds.citation",
  "name": "Citation",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/Citation/Citation.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "a"
  },
  "props": [
    {
      "name": "variant",
      "description": "Label chip with the source title, or a compact numbered badge. Don't mix both in one paragraph.",
      "type": {
        "enum": [
          "label",
          "number"
        ]
      },
      "default": "label",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Variant",
          "values": {
            "label": "Label",
            "number": "Number"
          }
        },
        "code": {
          "prop": "variant"
        }
      }
    },
    {
      "name": "sourceTitle",
      "description": "The source's display title (label variant).",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Source Title"
        },
        "code": {
          "prop": "sourceTitle"
        }
      }
    },
    {
      "name": "number",
      "description": "Display index (number variant).",
      "type": "text",
      "default": "1",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Number"
        },
        "code": {
          "prop": "number"
        }
      }
    },
    {
      "name": "href",
      "description": "Source URL.",
      "type": "text",
      "default": "https://example.com",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Href"
        },
        "code": {
          "prop": "href"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "inline-flex",
        "direction": "row",
        "align": "center"
      },
      "tokens": {
        "background-color": "{color.surface.sunken}",
        "color": "{color.text.secondary}",
        "border-radius": "{radius.100}",
        "padding-inline": "{space.inset-x.xs}",
        "padding-block": "{space.inset-y.xs}",
        "font-family": "{font.control.family}",
        "font-size": "{font.badge.size}",
        "font-weight": "{font.control.weight}"
      },
      "parts": {
        "labelText": {
          "element": "span",
          "content": {
            "prop": "sourceTitle"
          },
          "visibleWhen": {
            "prop": "variant",
            "equals": "label"
          }
        },
        "numberText": {
          "element": "span",
          "content": {
            "prop": "number"
          },
          "visibleWhen": {
            "prop": "variant",
            "equals": "number"
          }
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/Citation/Citation",
      "export": "Citation"
    }
  }
}
