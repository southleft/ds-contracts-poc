{
  "$schema": "./contract.schema.json",
  "id": "ds.list",
  "name": "List",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/List/List.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "ul"
  },
  "props": [
    {
      "name": "density",
      "description": "Item spacing density.",
      "type": {
        "enum": [
          "compact",
          "balanced",
          "spacious"
        ]
      },
      "default": "balanced",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Density",
          "values": {
            "compact": "Compact",
            "balanced": "Balanced",
            "spacious": "Spacious"
          }
        },
        "code": {
          "prop": "density"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "flex",
        "direction": "column",
        "align": "stretch"
      },
      "tokens": {
        "max-width": "{size.card.width}",
        "background-color": "{color.surface.raised}",
        "border-color": "{color.border.subtle}",
        "border-width": "{border-width.100}",
        "border-radius": "{radius.card}",
        "padding-inline": "{space.inset-y.sm}",
        "padding-block": "{space.inset-y.sm}",
        "gap": "{space.list.{density}}"
      },
      "parts": {
        "items": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "column",
            "align": "stretch"
          },
          "tokens": {
            "gap": "{space.list.{density}}"
          },
          "slot": {
            "name": "children"
          }
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/List/List",
      "export": "List"
    }
  }
}
