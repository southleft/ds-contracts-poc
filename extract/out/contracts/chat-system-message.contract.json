{
  "$schema": "./contract.schema.json",
  "id": "ds.chat-system-message",
  "name": "ChatSystemMessage",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/ChatSystemMessage/ChatSystemMessage.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "variant",
      "description": "Plain centered text, or text between divider lines.",
      "type": {
        "enum": [
          "default",
          "divider"
        ]
      },
      "default": "default",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Variant",
          "values": {
            "default": "Default",
            "divider": "Divider"
          }
        },
        "code": {
          "prop": "variant"
        }
      }
    },
    {
      "name": "message",
      "description": "Short factual string — a date, a join notice, a status change.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Message"
        },
        "code": {
          "prop": "message"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "flex",
        "direction": "row",
        "align": "center",
        "justify": "center"
      },
      "tokens": {
        "max-width": "{size.card.width}",
        "gap": "{space.gap.sm}",
        "font-family": "{font.control.family}",
        "font-size": "{font.badge.size}",
        "color": "{color.text.secondary}"
      },
      "parts": {
        "lineStart": {
          "element": "div",
          "layout": {
            "display": "flex",
            "grow": true
          },
          "tokens": {
            "height": "{border.width.divider.subtle}",
            "background-color": "{color.divider.subtle}"
          },
          "visibleWhen": {
            "prop": "variant",
            "equals": "divider"
          }
        },
        "iconSlot": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center"
          },
          "slot": {
            "name": "icon"
          },
          "optional": true
        },
        "messageText": {
          "element": "span",
          "content": {
            "prop": "message"
          }
        },
        "lineEnd": {
          "element": "div",
          "layout": {
            "display": "flex",
            "grow": true
          },
          "tokens": {
            "height": "{border.width.divider.subtle}",
            "background-color": "{color.divider.subtle}"
          },
          "visibleWhen": {
            "prop": "variant",
            "equals": "divider"
          }
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/ChatSystemMessage/ChatSystemMessage",
      "export": "ChatSystemMessage"
    }
  }
}
