{
  "$schema": "./contract.schema.json",
  "id": "ds.switch",
  "name": "Switch",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/Switch/Switch.tsx (react-tsx adapter) — API surface only; anatomy, tokens, and design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "value",
      "description": "On or off — drives the track color and thumb position.",
      "type": {
        "enum": [
          "off",
          "on"
        ]
      },
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Value",
          "values": {
            "off": "Off",
            "on": "On"
          }
        },
        "code": {
          "prop": "value"
        }
      }
    },
    {
      "name": "label",
      "description": "Always rendered — users must know what they are toggling.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "label"
        }
      }
    },
    {
      "name": "description",
      "description": "Secondary text below the label.",
      "type": "text",
      "default": "Takes effect immediately.",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Description"
        },
        "code": {
          "prop": "description"
        }
      }
    }
  ],
  "events": [
    {
      "name": "toggle",
      "description": "Fires when the track is activated; uncontrolled instances flip value off/on themselves.",
      "bindings": {
        "code": {
          "prop": "onToggle"
        }
      },
      "trigger": "root"
    }
  ],
  "states": [],
  "anatomy": {
    "root": {}
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/Switch/Switch",
      "export": "Switch"
    }
  }
}
