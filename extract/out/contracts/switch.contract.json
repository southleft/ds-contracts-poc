{
  "$schema": "./contract.schema.json",
  "id": "ds.switch",
  "name": "Switch",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/Switch/Switch.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "label"
  },
  "props": [
    {
      "name": "value",
      "description": "On or off — drives the track color and thumb position.",
      "type": {
        "enum": [
          "off",
          "on"
        ]
      },
      "default": "off",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Value",
          "values": {
            "off": "Off",
            "on": "On"
          }
        },
        "code": {
          "prop": "value"
        }
      }
    },
    {
      "name": "label",
      "description": "Always rendered — users must know what they are toggling.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "label"
        }
      }
    },
    {
      "name": "description",
      "description": "Secondary text below the label.",
      "type": "text",
      "default": "Takes effect immediately.",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Description"
        },
        "code": {
          "prop": "description"
        }
      }
    }
  ],
  "events": [
    {
      "name": "toggle",
      "description": "Fires when the input is toggled; uncontrolled instances flip value off/on themselves.",
      "bindings": {
        "code": {
          "prop": "onToggle"
        }
      },
      "trigger": "input",
      "toggles": {
        "prop": "value",
        "between": [
          "off",
          "on"
        ],
        "aria": "checked"
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "flex",
        "direction": "row",
        "align": "start"
      },
      "tokens": {
        "gap": "{space.gap.sm}",
        "font-family": "{font.control.family}",
        "color": "{color.surface.foreground}"
      },
      "parts": {
        "track": {
          "element": "span",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center"
          },
          "tokens": {
            "width": "{size.switch.width}",
            "height": "{size.switch.height}",
            "border-radius": "{radius.pill}",
            "padding-inline": "{space.inset-y.xs}",
            "padding-block": "{space.inset-y.xs}",
            "background-color": "{color.switch.{value}.track}"
          },
          "parts": {
            "input": {
              "element": "input",
              "attrs": {
                "type": "checkbox",
                "role": "switch"
              }
            },
            "spacerStart": {
              "element": "div",
              "layout": {
                "display": "flex",
                "grow": true
              },
              "visibleWhen": {
                "prop": "value",
                "equals": "on"
              }
            },
            "thumb": {
              "element": "span",
              "tokens": {
                "width": "{size.switch.thumb}",
                "height": "{size.switch.thumb}",
                "background-color": "{color.switch.thumb}",
                "border-radius": "{radius.pill}"
              }
            },
            "spacerEnd": {
              "element": "div",
              "layout": {
                "display": "flex",
                "grow": true
              },
              "visibleWhen": {
                "prop": "value",
                "equals": "off"
              }
            }
          }
        },
        "textCol": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "column",
            "grow": true
          },
          "tokens": {
            "gap": "{space.inset-y.xs}"
          },
          "parts": {
            "labelText": {
              "element": "span",
              "tokens": {
                "font-size": "{font.control.size.sm}",
                "font-weight": "{font.control.weight}"
              },
              "content": {
                "prop": "label"
              }
            },
            "descriptionText": {
              "element": "span",
              "tokens": {
                "font-size": "{font.control.size.sm}",
                "color": "{color.text.secondary}"
              },
              "content": {
                "prop": "description"
              }
            }
          }
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/Switch/Switch",
      "export": "Switch"
    }
  }
}
