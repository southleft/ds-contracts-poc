{
  "$schema": "./contract.schema.json",
  "id": "ds.card",
  "name": "Card",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/Card/Card.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "article"
  },
  "props": [
    {
      "name": "title",
      "description": "Card heading, bound to the header title part on both surfaces.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Title"
        },
        "code": {
          "prop": "title"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "flex",
        "direction": "column",
        "align": "stretch"
      },
      "tokens": {
        "background-color": "{color.surface.raised}",
        "border-color": "{color.border.subtle}",
        "border-width": "{border-width.100}",
        "border-radius": "{radius.card}",
        "max-width": "{size.card.width}"
      },
      "parts": {
        "header": {
          "element": "header",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center"
          },
          "tokens": {
            "gap": "{space.gap.control}",
            "padding-inline": "{space.inset-x.md}",
            "padding-block": "{space.inset-y.md}"
          },
          "parts": {
            "avatar": {
              "component": {
                "id": "ds.avatar",
                "props": {
                  "size": "sm"
                },
                "text": "AB"
              }
            },
            "title": {
              "element": "span",
              "tokens": {
                "color": "{color.surface.foreground}",
                "font-family": "{font.control.family}",
                "font-size": "{font.title.size}",
                "font-weight": "{font.title.weight}"
              },
              "content": {
                "prop": "title"
              }
            }
          }
        },
        "body": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "column",
            "align": "stretch"
          },
          "tokens": {
            "gap": "{space.gap.control}",
            "padding-inline": "{space.inset-x.md}",
            "padding-block": "{space.inset-y.md}",
            "color": "{color.surface.foreground}",
            "font-family": "{font.control.family}",
            "font-size": "{font.control.size.sm}"
          },
          "slot": {
            "name": "children"
          }
        },
        "footer": {
          "element": "footer",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center",
            "justify": "end"
          },
          "tokens": {
            "gap": "{space.gap.control}",
            "padding-inline": "{space.inset-x.md}",
            "padding-block": "{space.inset-y.md}"
          },
          "slot": {
            "name": "actions"
          },
          "optional": true
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/Card/Card",
      "export": "Card"
    }
  }
}
