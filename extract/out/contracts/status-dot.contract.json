{
  "$schema": "./contract.schema.json",
  "id": "ds.status-dot",
  "name": "StatusDot",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/StatusDot/StatusDot.tsx (react-tsx adapter) — API surface only; anatomy, tokens, and design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "variant",
      "description": "Semantic color variant.",
      "type": {
        "enum": [
          "success",
          "warning",
          "error",
          "accent",
          "neutral"
        ]
      },
      "default": "neutral",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Variant",
          "values": {
            "success": "Success",
            "warning": "Warning",
            "error": "Error",
            "accent": "Accent",
            "neutral": "Neutral"
          }
        },
        "code": {
          "prop": "variant"
        }
      }
    },
    {
      "name": "label",
      "description": "Accessible label announced by screen readers — status must never be conveyed by color alone.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "label"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {}
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/StatusDot/StatusDot",
      "export": "StatusDot"
    }
  }
}
