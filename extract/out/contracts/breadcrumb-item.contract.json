{
  "$schema": "./contract.schema.json",
  "id": "ds.breadcrumb-item",
  "name": "BreadcrumbItem",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/BreadcrumbItem/BreadcrumbItem.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "span"
  },
  "props": [
    {
      "name": "hasSeparator",
      "description": "Leading separator — off for the first item in a trail.",
      "type": "boolean",
      "default": true,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Has Separator"
        },
        "code": {
          "prop": "hasSeparator"
        }
      }
    },
    {
      "name": "label",
      "description": "The crumb text.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "label"
        }
      }
    },
    {
      "name": "href",
      "description": "Navigation target. Current-page items conventionally point at themselves.",
      "type": "text",
      "default": "#",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Href"
        },
        "code": {
          "prop": "href"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "inline-flex",
        "direction": "row",
        "align": "center"
      },
      "tokens": {
        "gap": "{space.inset-y.sm}",
        "font-family": "{font.control.family}",
        "font-size": "{font.control.size.sm}"
      },
      "parts": {
        "separatorIcon": {
          "element": "span",
          "layout": {
            "display": "inline-flex"
          },
          "tokens": {
            "color": "{color.text.secondary}"
          },
          "visibleWhen": {
            "prop": "hasSeparator"
          }
        },
        "link": {
          "element": "a",
          "tokens": {
            "color": "{color.text.secondary}"
          },
          "content": {
            "prop": "label"
          },
          "attrs": {
            "href": "{href}"
          }
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/BreadcrumbItem/BreadcrumbItem",
      "export": "BreadcrumbItem"
    }
  }
}
