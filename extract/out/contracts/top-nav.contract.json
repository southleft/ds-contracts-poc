{
  "$schema": "./contract.schema.json",
  "id": "ds.top-nav",
  "name": "TopNav",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/TopNav/TopNav.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "nav"
  },
  "props": [
    {
      "name": "label",
      "description": "Accessible label for the navigation landmark.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "label"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "flex",
        "direction": "row",
        "align": "center",
        "justify": "space-between"
      },
      "tokens": {
        "max-width": "{size.banner.width}",
        "background-color": "{color.surface.raised}",
        "border-color": "{color.border.subtle}",
        "border-width": "{border-width.100}",
        "gap": "{space.gap.md}",
        "padding-inline": "{space.inset-x.md}",
        "padding-block": "{space.inset-y.md}"
      },
      "parts": {
        "heading": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center"
          },
          "tokens": {
            "gap": "{space.gap.sm}"
          },
          "slot": {
            "name": "heading"
          },
          "optional": true
        },
        "startContent": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center",
            "grow": true
          },
          "tokens": {
            "gap": "{space.inset-y.sm}"
          },
          "slot": {
            "name": "startContent"
          },
          "optional": true
        },
        "endContent": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center"
          },
          "tokens": {
            "gap": "{space.gap.sm}"
          },
          "slot": {
            "name": "endContent"
          },
          "optional": true
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/TopNav/TopNav",
      "export": "TopNav"
    }
  }
}
