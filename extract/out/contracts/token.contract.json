{
  "$schema": "./contract.schema.json",
  "id": "ds.token",
  "name": "Token",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/Token/Token.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "span"
  },
  "props": [
    {
      "name": "color",
      "description": "Color variant.",
      "type": {
        "enum": [
          "default",
          "red",
          "orange",
          "yellow",
          "green",
          "teal",
          "cyan",
          "blue",
          "purple",
          "pink",
          "gray"
        ]
      },
      "default": "default",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Color",
          "values": {
            "default": "Default",
            "red": "Red",
            "orange": "Orange",
            "yellow": "Yellow",
            "green": "Green",
            "teal": "Teal",
            "cyan": "Cyan",
            "blue": "Blue",
            "purple": "Purple",
            "pink": "Pink",
            "gray": "Gray"
          }
        },
        "code": {
          "prop": "color"
        }
      }
    },
    {
      "name": "size",
      "description": "Token size.",
      "type": {
        "enum": [
          "sm",
          "md",
          "lg"
        ]
      },
      "default": "md",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Size",
          "values": {
            "sm": "Sm",
            "md": "Md",
            "lg": "Lg"
          }
        },
        "code": {
          "prop": "size"
        }
      }
    },
    {
      "name": "isDisabled",
      "description": "Reduces opacity and blocks interactions.",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Is Disabled"
        },
        "code": {
          "prop": "isDisabled"
        }
      }
    },
    {
      "name": "label",
      "description": "Text label inside the token.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "label"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "inline-flex",
        "direction": "row",
        "align": "center"
      },
      "tokens": {
        "border-radius": "{radius.100}",
        "gap": "{space.inset-y.sm}",
        "padding-inline": "{space.inset-x.xs}",
        "padding-block": "{space.inset-y.xs}",
        "font-family": "{font.control.family}",
        "font-size": "{font.badge.size}",
        "font-weight": "{font.control.weight}",
        "background-color": "{color.token.{color}.background}",
        "color": "{color.token.{color}.foreground}"
      },
      "parts": {
        "iconSlot": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center"
          },
          "slot": {
            "name": "icon"
          },
          "optional": true
        },
        "labelText": {
          "element": "span",
          "content": {
            "prop": "label"
          }
        },
        "endContent": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center"
          },
          "slot": {
            "name": "endContent"
          },
          "optional": true
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/Token/Token",
      "export": "Token"
    }
  }
}
