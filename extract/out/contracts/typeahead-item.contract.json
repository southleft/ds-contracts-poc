{
  "$schema": "./contract.schema.json",
  "id": "ds.typeahead-item",
  "name": "TypeaheadItem",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/TypeaheadItem/TypeaheadItem.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div",
    "role": "option"
  },
  "props": [
    {
      "name": "label",
      "description": "Primary result text.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "label"
        }
      }
    },
    {
      "name": "description",
      "description": "Secondary text below the label.",
      "type": "text",
      "default": "Supporting detail about this result.",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Description"
        },
        "code": {
          "prop": "description"
        }
      }
    }
  ],
  "states": [
    "hover"
  ],
  "anatomy": {
    "root": {
      "layout": {
        "display": "flex",
        "direction": "row",
        "align": "center"
      },
      "tokens": {
        "max-width": "{size.card.width}",
        "background-color": "{color.surface.raised}",
        "border-radius": "{radius.100}",
        "gap": "{space.gap.sm}",
        "padding-inline": "{space.inset-x.sm}",
        "padding-block": "{space.inset-y.md}",
        "font-family": "{font.control.family}",
        "color": "{color.surface.foreground}"
      },
      "states": {
        "hover": {
          "background-color": "{color.surface.sunken}"
        }
      },
      "parts": {
        "iconSlot": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center"
          },
          "slot": {
            "name": "icon"
          },
          "optional": true
        },
        "textCol": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "column",
            "grow": true
          },
          "tokens": {
            "gap": "{space.inset-y.xs}"
          },
          "parts": {
            "labelText": {
              "element": "span",
              "tokens": {
                "font-size": "{font.control.size.sm}",
                "font-weight": "{font.control.weight}"
              },
              "content": {
                "prop": "label"
              }
            },
            "descriptionText": {
              "element": "span",
              "tokens": {
                "font-size": "{font.control.size.sm}",
                "color": "{color.text.secondary}"
              },
              "content": {
                "prop": "description"
              }
            }
          }
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/TypeaheadItem/TypeaheadItem",
      "export": "TypeaheadItem"
    }
  }
}
