{
  "$schema": "./contract.schema.json",
  "id": "ds.empty-state",
  "name": "EmptyState",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from src/components/EmptyState/EmptyState.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "title",
      "description": "Primary message.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Title"
        },
        "code": {
          "prop": "title"
        }
      }
    },
    {
      "name": "description",
      "description": "Secondary text explaining what will appear here and how.",
      "type": "text",
      "default": "When items are added they will show up in this list.",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Description"
        },
        "code": {
          "prop": "description"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "flex",
        "direction": "column",
        "align": "center"
      },
      "tokens": {
        "max-width": "{size.card.width}",
        "gap": "{space.gap.sm}",
        "padding-inline": "{space.inset-x.lg}",
        "padding-block": "{space.inset-x.lg}",
        "font-family": "{font.control.family}",
        "color": "{color.surface.foreground}"
      },
      "parts": {
        "iconArea": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center",
            "justify": "center"
          },
          "slot": {
            "name": "icon"
          },
          "attrs": {
            "aria-hidden": "true"
          },
          "optional": true
        },
        "title": {
          "element": "span",
          "tokens": {
            "font-size": "{font.control.size.md}",
            "font-weight": "{font.title.weight}"
          },
          "content": {
            "prop": "title"
          }
        },
        "descriptionText": {
          "element": "span",
          "tokens": {
            "font-size": "{font.control.size.sm}",
            "color": "{color.text.secondary}"
          },
          "content": {
            "prop": "description"
          }
        },
        "actions": {
          "element": "div",
          "layout": {
            "display": "flex",
            "direction": "row",
            "align": "center"
          },
          "tokens": {
            "gap": "{space.gap.sm}",
            "padding-block": "{space.inset-y.sm}"
          },
          "slot": {
            "name": "actions"
          },
          "optional": true
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "src/components/EmptyState/EmptyState",
      "export": "EmptyState"
    }
  }
}
