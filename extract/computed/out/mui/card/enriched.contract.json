{
  "$schema": "./contract.schema.json",
  "id": "mui.card",
  "name": "Card",
  "version": "0.1.0",
  "status": "draft",
  "description": "SEED contract for the MUI computed-floor round — props/axes only; anatomy is promoted from captured DOM truth (Round 4). Subject: @mui/material@9.2.0 (pinned, examples/mui/PROVENANCE.md). COMPUTED-ENRICHED (extract/computed): unlabeled styled channels minted from computed-style capture of @mui/material@9.2.0 in headless Chromium 149.0.7827.55; overflow channels in the sibling extension file.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "elevation",
      "type": {
        "enum": [
          "0",
          "1",
          "3",
          "8"
        ]
      },
      "default": "1",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Elevation",
          "values": {
            "0": "0",
            "1": "1",
            "3": "3",
            "8": "8"
          }
        },
        "code": {
          "prop": "elevation"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "declared": {
        "display": "block",
        "overflow-x": "hidden",
        "overflow-y": "hidden",
        "transition-duration": "0.3s",
        "transition-property": "box-shadow",
        "transition-timing-function": "cubic-bezier(0.4, 0, 0.2, 1)"
      },
      "tokens": {
        "background-color": "{imported.card.root.background-color}",
        "border-bottom-left-radius": "{imported.shared.size-4}",
        "border-bottom-right-radius": "{imported.shared.size-4}",
        "border-top-left-radius": "{imported.shared.size-4}",
        "border-top-right-radius": "{imported.shared.size-4}",
        "color": "{imported.card.root.color}",
        "font-size": "{imported.card.root.font-size}",
        "font-weight": "{imported.card.root.font-weight}",
        "row-rule-color": "{imported.card.root.row-rule-color}"
      },
      "tokensByProp": [
        {
          "prop": "elevation",
          "map": {
            "0": {
              "box-shadow": "{imported.card.root.box-shadow.0}"
            },
            "1": {
              "box-shadow": "{imported.card.root.box-shadow.1}"
            },
            "3": {
              "box-shadow": "{imported.card.root.box-shadow.3}"
            },
            "8": {
              "box-shadow": "{imported.card.root.box-shadow.8}"
            }
          }
        }
      ]
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "@mui/material",
      "export": "Card"
    }
  }
