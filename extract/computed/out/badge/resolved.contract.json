              "color": "{color-text-yellow}"
            }
          }
        },
        {
          "prop": "variant",
          "map": {
            "blue": {
              "row-rule-color": "{imported.badge.root.row-rule-color.blue}"
            },
            "cyan": {
              "row-rule-color": "{imported.badge.root.row-rule-color.cyan}"
            },
