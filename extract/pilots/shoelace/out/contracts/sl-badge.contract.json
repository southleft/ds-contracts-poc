{
  "$schema": "./contract.schema.json",
  "id": "sl.sl-badge",
  "name": "SlBadge",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from extract/pilots/shoelace/custom-elements.json (components/badge/badge.js) (cem adapter) — API surface only; anatomy, tokens, and design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "variant",
      "description": "The badge's theme variant.",
      "type": {
        "enum": [
          "primary",
          "success",
          "neutral",
          "warning",
          "danger"
        ]
      },
      "default": "primary",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Variant",
          "values": {
            "primary": "Primary",
            "success": "Success",
            "neutral": "Neutral",
            "warning": "Warning",
            "danger": "Danger"
          }
        },
        "code": {
          "prop": "variant"
        }
      }
    },
    {
      "name": "pill",
      "description": "Draws a pill-style badge with rounded edges.",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Pill"
        },
        "code": {
          "prop": "pill"
        }
      }
    },
    {
      "name": "pulse",
      "description": "Makes the badge pulsate to draw attention.",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Pulse"
        },
        "code": {
          "prop": "pulse"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {}
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "extract/pilots/shoelace/custom-elements.json (components/badge/badge.js)",
      "export": "SlBadge"
    }
  }
}
