{
  "$schema": "./contract.schema.json",
  "id": "sl.sl-radio",
  "name": "SlRadio",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from extract/pilots/shoelace/custom-elements.json (components/radio/radio.js) (cem adapter) — API surface only; anatomy, tokens, and design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "value",
      "description": "The radio's value. When selected, the radio group will receive this value.",
      "type": "text",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Value"
        },
        "code": {
          "prop": "value"
        }
      }
    },
    {
      "name": "size",
      "description": "The radio's size. When used inside a radio group, the size will be determined by the radio group's size so this\nattribute can typically be omitted.",
      "type": {
        "enum": [
          "small",
          "medium",
          "large"
        ]
      },
      "default": "medium",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Size",
          "values": {
            "small": "Small",
            "medium": "Medium",
            "large": "Large"
          }
        },
        "code": {
          "prop": "size"
        }
      }
    },
    {
      "name": "disabled",
      "description": "Disables the radio.",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Disabled"
        },
        "code": {
          "prop": "disabled"
        }
      }
    },
    {
      "name": "checked",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Checked"
        },
        "code": {
          "prop": "checked"
        }
      }
    }
  ],
  "events": [
    {
      "name": "blur",
      "description": "Emitted when the control loses focus. (CEM event \"sl-blur\")",
      "bindings": {
        "code": {
          "prop": "onBlur"
        }
      },
      "trigger": "root"
    },
    {
      "name": "focus",
      "description": "Emitted when the control gains focus. (CEM event \"sl-focus\")",
      "bindings": {
        "code": {
          "prop": "onFocus"
        }
      },
      "trigger": "root"
    }
  ],
  "states": [],
  "anatomy": {
    "root": {}
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "extract/pilots/shoelace/custom-elements.json (components/radio/radio.js)",
      "export": "SlRadio"
    }
  }
}
