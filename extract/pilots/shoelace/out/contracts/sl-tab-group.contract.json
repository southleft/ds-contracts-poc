{
  "$schema": "./contract.schema.json",
  "id": "sl.sl-tab-group",
  "name": "SlTabGroup",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from extract/pilots/shoelace/custom-elements.json (components/tab-group/tab-group.js) (cem adapter) — API surface only; anatomy, tokens, and design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "placement",
      "description": "The placement of the tabs.",
      "type": {
        "enum": [
          "top",
          "bottom",
          "start",
          "end"
        ]
      },
      "default": "top",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Placement",
          "values": {
            "top": "Top",
            "bottom": "Bottom",
            "start": "Start",
            "end": "End"
          }
        },
        "code": {
          "prop": "placement"
        }
      }
    },
    {
      "name": "activation",
      "description": "When set to auto, navigating tabs with the arrow keys will instantly show the corresponding tab panel. When set to\nmanual, the tab will receive focus but will not show until the user presses spacebar or enter.",
      "type": {
        "enum": [
          "auto",
          "manual"
        ]
      },
      "default": "auto",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Activation",
          "values": {
            "auto": "Auto",
            "manual": "Manual"
          }
        },
        "code": {
          "prop": "activation"
        }
      }
    },
    {
      "name": "no-scroll-controls",
      "description": "Disables the scroll arrows that appear when tabs overflow.",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "No Scroll Controls"
        },
        "code": {
          "prop": "no-scroll-controls"
        }
      }
    },
    {
      "name": "fixed-scroll-controls",
      "description": "Prevent scroll buttons from being hidden when inactive.",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Fixed Scroll Controls"
        },
        "code": {
          "prop": "fixed-scroll-controls"
        }
      }
    },
    {
      "name": "noScrollControls",
      "description": "Disables the scroll arrows that appear when tabs overflow.",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
