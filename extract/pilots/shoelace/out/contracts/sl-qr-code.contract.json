{
  "$schema": "./contract.schema.json",
  "id": "sl.sl-qr-code",
  "name": "SlQrCode",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from extract/pilots/shoelace/custom-elements.json (components/qr-code/qr-code.js) (cem adapter) — API surface only; anatomy, tokens, and design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "value",
      "description": "The QR code's value.",
      "type": "text",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Value"
        },
        "code": {
          "prop": "value"
        }
      }
    },
    {
      "name": "label",
      "description": "The label for assistive devices to announce. If unspecified, the value will be used instead.",
      "type": "text",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "label"
        }
      }
    },
    {
      "name": "size",
      "description": "The size of the QR code, in pixels.",
      "type": "number",
      "default": 128,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Size"
        },
        "code": {
          "prop": "size"
        }
      }
    },
    {
      "name": "fill",
      "description": "The fill color. This can be any valid CSS color, but not a CSS custom property.",
      "type": "text",
      "default": "black",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Fill"
        },
        "code": {
          "prop": "fill"
        }
      }
    },
    {
      "name": "background",
      "description": "The background color. This can be any valid CSS color or `transparent`. It cannot be a CSS custom property.",
      "type": "text",
      "default": "white",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Background"
        },
        "code": {
          "prop": "background"
        }
      }
    },
    {
      "name": "radius",
      "description": "The edge radius of each module. Must be between 0 and 0.5.",
      "type": "number",
      "default": 0,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Radius"
        },
        "code": {
          "prop": "radius"
        }
      }
    },
    {
      "name": "error-correction",
      "description": "The level of error correction to use. [Learn more](https://www.qrcode.com/en/about/error_correction.html)",
      "type": {
        "enum": [
          "L",
          "M",
          "Q",
          "H"
        ]
      },
      "default": "H",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Error Correction",
          "values": {
            "L": "L",
            "M": "M",
            "Q": "Q",
            "H": "H"
          }
        },
        "code": {
          "prop": "error-correction"
        }
      }
    },
    {
      "name": "errorCorrection",
      "description": "The level of error correction to use. [Learn more](https://www.qrcode.com/en/about/error_correction.html)",
      "type": {
        "enum": [
          "L",
          "M",
          "Q",
          "H"
        ]
      },
      "default": "H",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Error Correction",
          "values": {
            "L": "L",
            "M": "M",
            "Q": "Q",
            "H": "H"
          }
        },
        "code": {
          "prop": "errorCorrection"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {}
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "extract/pilots/shoelace/custom-elements.json (components/qr-code/qr-code.js)",
      "export": "SlQrCode"
    }
  }
}
