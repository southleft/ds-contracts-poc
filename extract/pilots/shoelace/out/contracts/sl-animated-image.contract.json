{
  "$schema": "./contract.schema.json",
  "id": "sl.sl-animated-image",
  "name": "SlAnimatedImage",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from extract/pilots/shoelace/custom-elements.json (components/animated-image/animated-image.js) (cem adapter) — API surface only; anatomy, tokens, and design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "src",
      "description": "The path to the image to load.",
      "type": "text",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Src"
        },
        "code": {
          "prop": "src"
        }
      }
    },
    {
      "name": "alt",
      "description": "A description of the image used by assistive devices.",
      "type": "text",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Alt"
        },
        "code": {
          "prop": "alt"
        }
      }
    },
    {
      "name": "play",
      "description": "Plays the animation. When this attribute is remove, the animation will pause.",
      "type": "boolean",
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Play"
        },
        "code": {
          "prop": "play"
        }
      }
    },
    {
      "name": "frozenFrame",
      "type": "text",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Frozen Frame"
        },
        "code": {
          "prop": "frozenFrame"
        }
      }
    },
    {
      "name": "isLoaded",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Is Loaded"
        },
        "code": {
          "prop": "isLoaded"
        }
      }
    }
  ],
  "events": [
    {
      "name": "load",
      "description": "Emitted when the image loads successfully. (CEM event \"sl-load\")",
      "bindings": {
        "code": {
          "prop": "onLoad"
        }
      },
      "trigger": "root"
    },
    {
      "name": "error",
      "description": "Emitted when the image fails to load. (CEM event \"sl-error\")",
      "bindings": {
        "code": {
          "prop": "onError"
        }
      },
      "trigger": "root"
    }
  ],
  "states": [],
  "anatomy": {
    "root": {}
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "extract/pilots/shoelace/custom-elements.json (components/animated-image/animated-image.js)",
      "export": "SlAnimatedImage"
    }
  }
}
