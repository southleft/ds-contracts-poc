{
  "$schema": "./contract.schema.json",
  "id": "sl.sl-tag",
  "name": "SlTag",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from extract/pilots/shoelace/custom-elements.json (components/tag/tag.js) (cem adapter) — API surface only; anatomy, tokens, and design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "variant",
      "description": "The tag's theme variant.",
      "type": {
        "enum": [
          "primary",
          "success",
          "neutral",
          "warning",
          "danger",
          "text"
        ]
      },
      "default": "neutral",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Variant",
          "values": {
            "primary": "Primary",
            "success": "Success",
            "neutral": "Neutral",
            "warning": "Warning",
            "danger": "Danger",
            "text": "Text"
          }
        },
        "code": {
          "prop": "variant"
        }
      }
    },
    {
      "name": "size",
      "description": "The tag's size.",
      "type": {
        "enum": [
          "small",
          "medium",
          "large"
        ]
      },
      "default": "medium",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Size",
          "values": {
            "small": "Small",
            "medium": "Medium",
            "large": "Large"
          }
        },
        "code": {
          "prop": "size"
        }
      }
    },
    {
      "name": "pill",
      "description": "Draws a pill-style tag with rounded edges.",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Pill"
        },
        "code": {
          "prop": "pill"
        }
      }
    },
    {
      "name": "removable",
      "description": "Makes the tag removable and shows a remove button.",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Removable"
        },
        "code": {
          "prop": "removable"
        }
      }
    }
  ],
  "events": [
    {
      "name": "remove",
      "description": "Emitted when the remove button is activated. (CEM event \"sl-remove\")",
      "bindings": {
        "code": {
          "prop": "onRemove"
        }
      },
      "trigger": "root"
    }
  ],
  "states": [],
  "anatomy": {
    "root": {}
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "extract/pilots/shoelace/custom-elements.json (components/tag/tag.js)",
      "export": "SlTag"
    }
  }
}
