{
  "$schema": "./contract.schema.json",
  "id": "sl.sl-option",
  "name": "SlOption",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from extract/pilots/shoelace/custom-elements.json (components/option/option.js) (cem adapter) — API surface only; anatomy, tokens, and design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "value",
      "description": "The option's value. When selected, the containing form control will receive this value. The value must be unique\nfrom other options in the same group. Values may not contain spaces, as spaces are used as delimiters when listing\nmultiple values.",
      "type": "text",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Value"
        },
        "code": {
          "prop": "value"
        }
      }
    },
    {
      "name": "disabled",
      "description": "Draws the option in a disabled state, preventing selection.",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Disabled"
        },
        "code": {
          "prop": "disabled"
        }
      }
    },
    {
      "name": "current",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Current"
        },
        "code": {
          "prop": "current"
        }
      }
    },
    {
      "name": "selected",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Selected"
        },
        "code": {
          "prop": "selected"
        }
      }
    },
    {
      "name": "hasHover",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Has Hover"
        },
        "code": {
          "prop": "hasHover"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {}
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "extract/pilots/shoelace/custom-elements.json (components/option/option.js)",
      "export": "SlOption"
    }
  }
}
