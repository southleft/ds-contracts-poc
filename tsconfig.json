{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": [
      "vite/client",
      "node"
    ]
  },
  "include": [
    "src",
    "scripts",
    "core",
    ".storybook",
    "extract",
    "parity",
    "evals"
  ],
  "exclude": [
    "extract/fixtures",
    "evals/.scratch",
    "evals/adherence",
    "evals/fixtures"
  ]
}
