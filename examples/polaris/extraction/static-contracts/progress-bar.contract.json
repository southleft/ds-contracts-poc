{
  "$schema": "../../../contracts/contract.schema.json",
  "id": "polaris.progress-bar",
  "name": "ProgressBar",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from examples/polaris/.polaris-clone/polaris-react/src/components/ProgressBar/ProgressBar.tsx (react-tsx + css-module adapters) — API surface AND anatomy (structure, token bindings, layout, states) read from source; design bindings await reconciliation and human review. PROMOTED showcase contract: API surface extracted mechanically from Shopify/polaris @ 2b1ea88625e0613853ca8577c9acd1980a90f382 (polaris-react 13.10.1, MIT © Shopify, extracted 2026-07-18); styling bindings promoted from the component's own module.css under the reviewed class map in examples/polaris/scripts/curation.ts — every carried binding and every named refusal is listed in examples/polaris/extraction/PROMOTION.md.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "progress",
      "description": "The progression of certain tasks",
      "type": "number",
      "default": 0,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Progress"
        },
        "code": {
          "prop": "progress"
        }
      }
    },
    {
      "name": "size",
      "description": "Size of progressbar",
      "type": {
        "enum": [
          "small",
          "medium",
          "large"
        ]
      },
      "default": "medium",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Size",
          "values": {
            "small": "Small",
            "medium": "Medium",
            "large": "Large"
          }
        },
        "code": {
          "prop": "size"
        }
      }
    },
    {
      "name": "animated",
      "description": "Whether the fill animation is triggered",
      "type": "boolean",
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Animated"
        },
        "code": {
          "prop": "animated"
        }
      }
    },
    {
      "name": "ariaLabelledBy",
      "description": "Id (ids) of element (elements) that describes progressbar",
      "type": "text",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Aria Labelled By"
        },
        "code": {
          "prop": "ariaLabelledBy"
        }
      }
    },
    {
      "name": "tone",
      "description": "Color of progressbar",
      "type": {
        "enum": [
          "highlight",
          "primary",
          "success",
          "critical"
        ]
      },
      "default": "highlight",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Tone",
          "values": {
            "highlight": "Highlight",
            "primary": "Primary",
            "success": "Success",
            "critical": "Critical"
          }
        },
        "code": {
          "prop": "tone"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "tokens": {
        "border-radius": "{p.border-radius-100}"
      },
      "tokensByProp": {
        "prop": "tone",
        "map": {
          "highlight": {
            "background-color": "{p.color-bg-fill-tertiary}"
          },
          "primary": {
            "background-color": "{p.color-bg-fill-tertiary}"
          },
          "success": {
            "background-color": "{p.color-bg-fill-tertiary}"
          },
          "critical": {
            "background-color": "{p.color-bg-fill-tertiary}"
          }
        }
      },
      "literalsByProp": [
        {
          "prop": "size",
          "map": {
            "small": {
              "height": "8px"
            },
            "medium": {
              "height": "16px"
            },
            "large": {
              "height": "32px"
            }
          }
        }
      ],
      "parts": {
        "indicator": {
          "element": "div",
          "tokensByProp": {
            "prop": "tone",
            "map": {
              "highlight": {
                "background-color": "{p.color-bg-fill-info}"
              },
              "primary": {
                "background-color": "{p.color-bg-fill-brand}"
              },
              "success": {
                "background-color": "{p.color-bg-fill-success}"
              },
              "critical": {
                "background-color": "{p.color-bg-fill-critical}"
              }
            }
          }
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "polaris-react/src/components/ProgressBar/ProgressBar",
      "export": "ProgressBar"
    }
  }
}
