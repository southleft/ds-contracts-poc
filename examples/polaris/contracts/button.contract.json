{
  "$schema": "../../../contracts/contract.schema.json",
  "id": "polaris.button",
  "name": "Button",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from examples/polaris/.polaris-clone/polaris-react/src/components/Button/Button.tsx (react-tsx adapter) — API surface only; anatomy, tokens, and design bindings await reconciliation and human review. PROMOTED showcase contract: API surface extracted mechanically from Shopify/polaris @ 2b1ea88625e0613853ca8577c9acd1980a90f382 (polaris-react 13.10.1, MIT © Shopify, extracted 2026-07-18); styling bindings promoted from the component's own module.css under the reviewed class map in examples/polaris/scripts/curation.ts — every carried binding and every named refusal is listed in examples/polaris/extraction/PROMOTION.md.",
  "semantics": {
    "element": "button"
  },
  "props": [
    {
      "name": "size",
      "description": "Changes the size of the button, giving it more or less padding",
      "type": {
        "enum": [
          "micro",
          "slim",
          "medium",
          "large"
        ]
      },
      "default": "medium",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Size",
          "values": {
            "micro": "Micro",
            "slim": "Slim",
            "medium": "Medium",
            "large": "Large"
          }
        },
        "code": {
          "prop": "size"
        }
      }
    },
    {
      "name": "textAlign",
      "description": "Changes the inner text alignment of the button",
      "type": {
        "enum": [
          "left",
          "right",
          "center",
          "start",
          "end"
        ]
      },
      "default": "center",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Text Align",
          "values": {
            "left": "Left",
            "right": "Right",
            "center": "Center",
            "start": "Start",
            "end": "End"
          }
        },
        "code": {
          "prop": "textAlign"
        }
      }
    },
    {
      "name": "fullWidth",
      "description": "Allows the button to grow to the width of its container",
      "type": "boolean",
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Full Width"
        },
        "code": {
          "prop": "fullWidth"
        }
      }
    },
    {
      "name": "removeUnderline",
      "description": "Removes underline from button text (including on interaction)",
      "type": "boolean",
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Remove Underline"
        },
        "code": {
          "prop": "removeUnderline"
        }
      }
    },
    {
      "name": "dataPrimaryLink",
      "description": "Indicates whether or not the button is the primary navigation link when rendered inside of an `IndexTable.Row`",
      "type": "boolean",
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Data Primary Link"
        },
        "code": {
          "prop": "dataPrimaryLink"
        }
      }
    },
    {
      "name": "tone",
      "description": "Sets the color treatment of the Button.",
      "type": {
        "enum": [
          "critical",
          "success"
        ]
      },
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Tone",
          "values": {
            "critical": "Critical",
            "success": "Success"
          }
        },
        "code": {
          "prop": "tone"
        }
      }
    },
    {
      "name": "variant",
      "description": "Changes the visual appearance of the Button.",
      "type": {
        "enum": [
          "plain",
          "primary",
          "secondary",
          "tertiary",
          "monochromePlain"
        ]
      },
      "default": "secondary",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Variant",
          "values": {
            "plain": "Plain",
            "primary": "Primary",
            "secondary": "Secondary",
            "tertiary": "Tertiary",
            "monochromePlain": "Monochrome Plain"
          }
        },
        "code": {
          "prop": "variant"
        }
      }
    }
  ],
  "states": [
    "disabled"
  ],
  "anatomy": {
    "root": {
      "layout": {
        "display": "inline-flex",
        "align": "center"
      },
      "tokens": {
        "border-radius": "{p.border-radius-200}",
        "gap": "{p.space-050}"
      },
      "tokensByProp": {
        "prop": "variant",
        "map": {
          "plain": {
            "color": "{p.color-text-link}"
          },
          "primary": {
            "background-color": "{p.color-bg-fill-brand}",
            "color": "{p.color-text-brand-on-bg-fill}",
            "box-shadow": "{p.shadow-button-primary}"
          },
          "secondary": {
            "background": "{p.color-bg-fill}",
            "color": "{p.color-text}",
            "box-shadow": "{p.shadow-button}"
          },
          "tertiary": {
            "color": "{p.color-text}"
          }
        }
      },
      "states": {
        "disabled": {
          "background": "{p.color-bg-fill-disabled}",
          "color": "{p.color-text-disabled}",
          "fill": "{p.color-icon-disabled}"
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "polaris-react/src/components/Button/Button",
      "export": "Button"
    }
  }
}
