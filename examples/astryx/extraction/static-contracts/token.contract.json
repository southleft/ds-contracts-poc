        "figma": {
          "kind": "VARIANT",
          "property": "Color",
          "values": {
            "default": "Default",
            "red": "Red",
            "orange": "Orange",
            "yellow": "Yellow",
            "green": "Green",
            "teal": "Teal",
            "cyan": "Cyan",
            "blue": "Blue",
            "purple": "Purple",
            "pink": "Pink",
            "gray": "Gray"
