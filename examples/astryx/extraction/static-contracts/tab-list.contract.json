{
  "$schema": "./contract.schema.json",
  "id": "astryx.tab-list",
  "name": "TabList",
  "version": "0.1.0",
  "status": "draft",
  "description": "PROPOSED contract extracted from examples/astryx/.astryx-sandbox/node_modules/@astryxdesign/core/src/TabList/TabList.tsx (react-tsx adapter) — API surface only; anatomy, tokens, and design bindings await reconciliation and human review.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "value",
      "description": "The currently selected tab value.",
      "type": "text",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Value"
        },
        "code": {
          "prop": "value"
        }
      }
    },
    {
      "name": "layout",
      "description": "Layout mode for tab sizing.\n- `'hug'` (default): each tab hugs its content width.\n- `'fill'`: tabs stretch equally to fill the container width.",
      "type": {
        "enum": [
          "hug",
          "fill"
        ]
      },
      "default": "hug",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Layout",
          "values": {
            "hug": "Hug",
            "fill": "Fill"
          }
        },
        "code": {
          "prop": "layout"
        }
      }
    },
    {
      "name": "hasDivider",
      "description": "Whether to show a bottom divider under the tab list.",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Has Divider"
        },
        "code": {
          "prop": "hasDivider"
        }
      }
    }
  ],
  "events": [
    {
      "name": "change",
      "description": "Callback fired when a tab is selected.",
      "bindings": {
        "code": {
          "prop": "onChange"
        }
      },
      "trigger": "root"
    }
  ],
  "states": [],
  "anatomy": {
    "root": {}
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "examples/astryx/.astryx-sandbox/node_modules/@astryxdesign/core/src/TabList/TabList",
      "export": "TabList"
    }
  }
}
