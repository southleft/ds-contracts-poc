      "type": "text",
      "default": "Context menu",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "label"
        }
      }
    },
    {
      "name": "isDisabled",
      "description": "When true, right-click shows the native browser context menu instead.",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Is Disabled"
        },
        "code": {
          "prop": "isDisabled"
        }
      }
    }
  ],
  "events": [
