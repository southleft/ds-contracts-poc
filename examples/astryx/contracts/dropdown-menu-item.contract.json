{
  "$schema": "./contract.schema.json",
  "id": "astryx.dropdown-menu-item",
  "name": "DropdownMenuItem",
  "version": "0.2.0",
  "status": "draft",
  "description": "PROMOTED from the Phase B composition-tier extraction (round 2, StyleX anatomy). One menu row \u2014 the repeated item of astryx.dropdown-menu. Curation receipts: the extracted anatomy leaned on the internal <Item> layout component (astryx.item); promotion FLATTENS it to the element row Item renders (a deep-internal contract is not part of the exhibit set), keeping the extracted StyleX token bindings verbatim. The extracted `description`/`endContent`/icon channels are deferred to a later round \u2014 this exhibit carries the label row, the composition proof's moving part.",
  "semantics": {
    "element": "button",
    "role": "menuitem"
  },
  "props": [
    {
      "name": "label",
      "description": "The menu item's label text.",
      "type": "text",
      "default": "Menu item",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "label"
        }
      }
    },
    {
      "name": "isDisabled",
      "description": "Whether the item is disabled.",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Is Disabled"
        },
        "code": {
          "prop": "isDisabled"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "flex",
        "direction": "row",
        "align": "center"
      },
      "tokens": {
        "padding-block": "{spacing-2}",
        "padding-inline": "{spacing-2}",
        "border-radius": "{radius-element}",
        "font-family": "{font-family-body}",
        "font-size": "{text-label-size}",
        "color": "{color-text-primary}"
      },
      "parts": {
        "label": {
          "element": "span",
          "content": {
            "prop": "label"
          }
        }
      }
    }
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "@astryxdesign/core",
      "export": "DropdownMenuItem"
    }
  }
}