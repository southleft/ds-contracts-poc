          "default",
          "primary",
          "secondary",
          "error",
          "success",
          "warning",
          "info"
        ]
      },
      "default": "default",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Color",
          "values": {
            "default": "Default",
            "primary": "Primary",
            "secondary": "Secondary",
            "error": "Error",
            "success": "Success",
            "warning": "Warning",
            "info": "Info"
