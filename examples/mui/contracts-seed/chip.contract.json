{
  "$schema": "./contract.schema.json",
  "id": "mui.chip",
  "name": "Chip",
  "version": "0.1.0",
  "status": "draft",
  "description": "SEED contract for the MUI computed-floor round \u2014 props/axes only; anatomy is promoted from captured DOM truth (Round 4). Subject: @mui/material@9.2.0 (pinned, examples/mui/PROVENANCE.md).",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "variant",
      "type": {
        "enum": [
          "filled",
          "outlined"
        ]
      },
      "default": "filled",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Variant",
          "values": {
            "filled": "Filled",
            "outlined": "Outlined"
          }
        },
        "code": {
          "prop": "variant"
        }
      }
    },
    {
      "name": "color",
      "type": {
        "enum": [
          "default",
          "primary",
          "secondary",
          "error",
          "success",
          "warning",
          "info"
        ]
      },
      "default": "default",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Color",
          "values": {
            "default": "Default",
            "primary": "Primary",
            "secondary": "Secondary",
            "error": "Error",
            "success": "Success",
            "warning": "Warning",
            "info": "Info"
          }
        },
        "code": {
          "prop": "color"
        }
      }
    },
    {
      "name": "size",
      "type": {
        "enum": [
          "small",
          "medium"
        ]
      },
      "default": "medium",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Size",
          "values": {
            "small": "Small",
            "medium": "Medium"
          }
        },
        "code": {
          "prop": "size"
        }
      }
    },
    {
      "name": "label",
      "type": "text",
      "default": "Chip",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "label"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {}
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "@mui/material",
      "export": "Chip"
    }
  }
}
