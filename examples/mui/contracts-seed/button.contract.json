{
  "$schema": "./contract.schema.json",
  "id": "mui.button",
  "name": "Button",
  "version": "0.1.0",
  "status": "draft",
  "description": "SEED contract for the MUI computed-floor round \u2014 props/axes only; anatomy is promoted from captured DOM truth (Round 4). Subject: @mui/material@9.2.0 (pinned, examples/mui/PROVENANCE.md).",
  "semantics": {
    "element": "button"
  },
  "props": [
    {
      "name": "variant",
      "type": {
        "enum": [
          "contained",
          "outlined",
          "text"
        ]
      },
      "default": "text",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Variant",
          "values": {
            "contained": "Contained",
            "outlined": "Outlined",
            "text": "Text"
          }
        },
        "code": {
          "prop": "variant"
        }
      }
    },
    {
      "name": "color",
      "type": {
        "enum": [
          "primary",
          "secondary",
          "error",
          "success",
          "warning",
          "info",
          "inherit"
        ]
      },
      "default": "primary",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Color",
          "values": {
            "primary": "Primary",
            "secondary": "Secondary",
            "error": "Error",
            "success": "Success",
            "warning": "Warning",
            "info": "Info",
            "inherit": "Inherit"
          }
        },
        "code": {
          "prop": "color"
        }
      }
    },
    {
      "name": "size",
      "type": {
        "enum": [
          "small",
          "medium",
          "large"
        ]
      },
      "default": "medium",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Size",
          "values": {
            "small": "Small",
            "medium": "Medium",
            "large": "Large"
          }
        },
        "code": {
          "prop": "size"
        }
      }
    },
    {
      "name": "disabled",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Disabled"
        },
        "code": {
          "prop": "disabled"
        }
      }
    },
    {
      "name": "children",
      "type": "text",
      "default": "Button",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "children"
        }
      }
    }
  ],
  "states": [
    "disabled",
    "active",
    "focus-visible",
    "hover"
  ],
  "anatomy": {
    "root": {}
  },
  "anchors": {
    "figma": {
      "fileKey": null,
      "componentSetKey": null
    },
    "code": {
      "importPath": "@mui/material",
      "export": "Button"
    }
  }
}
