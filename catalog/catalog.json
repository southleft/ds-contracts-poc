        "kind": "text",
        "description": "Badge label."
      },
      "slots": []
    },
    {
      "id": "ds.button",
      "name": "Button",
      "version": "1.2.0",
      "status": "draft",
      "description": "Triggers an action or event. Use one primary button per context.",
      "figma": {
        "representation": "component",
        "componentSetKey": "1b5d2a573f3f39404af396bdbe944a30ca0eaec3"
      },
      "props": [
        {
          "name": "variant",
          "type": [
            "primary",
            "secondary",
            "danger"
          ],
          "default": "primary",
          "description": "Visual prominence of the action."
        },
        {
          "name": "size",
          "type": [
            "sm",
            "md",
            "lg"
          ],
          "default": "md",
          "description": "Control density."
        },
        {
          "name": "disabled",
          "type": "boolean",
          "default": false,
          "description": "Prevents interaction and communicates unavailability."
        },
        {
          "name": "loading",
          "type": "boolean",
          "default": false,
          "description": "Shows a busy indicator while an async action resolves."
        }
      ],
      "children": {
        "kind": "text",
        "description": "Button label."
      },
      "slots": []
    },
    {
      "id": "ds.card",
      "name": "Card",
      "version": "1.1.0",
      "status": "draft",
      "description": "Groups related content behind one subject. Composes an Avatar, a bound title, a default body slot, and a constrained actions slot.",
      "figma": {
        "representation": "component",
        "componentSetKey": "7cd7011e4f2374161cd212f02992c7fd0f899430"
      },
      "props": [
        {
          "name": "title",
          "type": "string",
          "default": "Card title",
          "required": true,
          "description": "Card heading, bound to the header title part on both surfaces."
        }
      ],
      "children": {
        "kind": "slot",
        "accepts": [],
        "acceptsMode": "open",
        "description": "Default slot — the card's main content."
      },
      "slots": [
        {
          "prop": "actions",
          "accepts": [
            "Button",
            "Badge"
          ],
          "acceptsMode": "prefer",
          "optional": true,
          "description": "Constrained actions slot — only actions-grade components."
        }
      ]
    },
