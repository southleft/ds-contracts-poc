{
  "system": {
    "name": "DS Contracts POC",
    "catalogVersion": "0.1.0",
    "gitCommit": "0b59301",
    "source": "Compiled from contracts/*.contract.json + tokens/ + context/rules.json — do not edit."
  },
  "package": {
    "name": "ds-contracts-poc",
    "usage": "import { Button, Card, Table } from 'ds-contracts-poc'; import 'ds-contracts-poc/styles.css';",
    "stylesheet": "ds-contracts-poc/styles.css"
  },
  "rules": [
    {
      "id": "components-from-catalog",
      "statement": "Every UI element comes from the catalog. Unknown components are gaps to report, never to invent.",
      "enforcement": "judge"
    },
    {
      "id": "tokens-only",
      "statement": "No literal colors or pixel values anywhere. All styling flows through design tokens (var(--…)) — and in screens, styling flows only through components.",
      "enforcement": "judge"
    },
    {
      "id": "no-raw-equivalents",
      "statement": "Never use raw HTML elements the system provides a component for.",
      "forbiddenRawElements": [
        "button",
        "table",
        "input",
        "select"
      ],
      "enforcement": "judge"
    },
    {
      "id": "no-style-overrides",
      "statement": "No className or style props on system components. If a component can't express it, that's a gap in the contract — report it.",
      "enforcement": "judge"
    },
    {
      "id": "one-primary-action",
      "statement": "At most one primary Button per screen.",
      "enforcement": "judge"
    },
    {
      "id": "layout-via-primitives",
      "statement": "Compose layout with Stack and Inline, not hand-styled wrappers.",
      "enforcement": "judge"
    },
    {
      "id": "avatars-are-people",
      "statement": "Avatars represent people or entities, never decoration.",
      "enforcement": "agent"
    }
  ],
  "context": {
    "memory": "# System memory\n\nWhat this design system is and is for — the standing context every generating\nsurface reads before producing anything. Edit freely (or via Contract Hub's\nContext page); this ships inside the catalog.\n\n- This system serves data-dense B2B product surfaces: settings, directories,\n  billing, member management.\n- Tone: quiet and information-first. Color signals state, never decoration.\n- Density matters: tables and forms should hold up at compact rhythm.\n- When a request needs something the catalog lacks, report the gap — never\n  approximate with lookalikes.\n",
    "references": [
      "README.md"
    ],
    "guidance": "Memory is standing intent; rules are the constitution (judge-enforced where deterministic); references are consultable files for judgment calls. Deterministic checks always win over interpretation."
  },
