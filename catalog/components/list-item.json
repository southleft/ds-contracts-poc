  },
  "slots": [
    {
      "prop": "startContent",
      "accepts": [],
      "acceptsMode": "open",
      "optional": true,
      "description": "Leading content — icon or avatar."
    },
    {
      "prop": "endContent",
      "accepts": [
        "Badge"
      ],
      "acceptsMode": "prefer",
      "optional": true,
      "description": "Trailing content — badge, count, chevron."
    }
  ]
}
