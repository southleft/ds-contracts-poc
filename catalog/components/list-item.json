{
  "id": "ds.list-item",
  "name": "ListItem",
  "version": "1.0.0",
  "status": "draft",
  "description": "A single row in a List: label with optional description, leading and trailing content. API mirrors industry convention (Astryx ListItem); click/link behavior is a declared boundary.",
  "figma": {
