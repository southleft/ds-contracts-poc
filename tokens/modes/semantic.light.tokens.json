{
  "color": {
    "surface": {
      "background": {
        "$value": "{color.gray.50}"
      },
      "foreground": {
        "$value": "{color.gray.900}"
      },
      "$type": "color",
      "raised": {
        "$value": "{color.white}"
      }
    },
    "action": {
      "primary": {
        "background": {
          "$value": "{color.blue.600}"
        },
        "background-hover": {
          "$value": "{color.blue.700}"
        },
        "foreground": {
          "$value": "{color.white}"
        }
      },
      "secondary": {
        "background": {
          "$value": "{color.gray.200}"
        },
        "background-hover": {
          "$value": "{color.gray.300}"
        },
        "foreground": {
          "$value": "{color.gray.900}"
        }
      },
      "danger": {
        "background": {
          "$value": "{color.red.600}"
        },
        "background-hover": {
          "$value": "{color.red.700}"
        },
        "foreground": {
          "$value": "{color.white}"
        }
      },
      "$type": "color"
    },
    "border": {
      "focus": {
        "$value": "{color.blue.500}"
      },
      "$type": "color",
      "subtle": {
        "$value": "{color.gray.200}"
      }
    },
    "feedback": {
      "info": {
        "background": {
          "$value": "{color.blue.100}"
        },
        "foreground": {
          "$value": "{color.blue.700}"
        }
      },
      "success": {
        "background": {
          "$value": "{color.green.100}"
        },
        "foreground": {
          "$value": "{color.green.700}"
        }
      },
      "warning": {
        "background": {
          "$value": "{color.amber.100}"
        },
        "foreground": {
          "$value": "{color.amber.700}"
        }
      },
      "danger": {
        "background": {
          "$value": "{color.red.100}"
        },
        "foreground": {
          "$value": "{color.red.700}"
        }
      },
      "$type": "color"
    },
    "identity": {
      "$type": "color",
      "background": {
        "$value": "{color.blue.100}"
      },
      "foreground": {
        "$value": "{color.blue.700}"
      }
    }
  }
}
