{
  "$schema": "./contract.schema.json",
  "id": "ds.avatar-group",
  "name": "AvatarGroup",
  "version": "1.0.0",
  "status": "draft",
  "description": "Stacked avatars with an overflow count. API mirrors industry convention (Astryx AvatarGroup): overlapping layout — expressed as a negative-margin child rule in CSS and negative item spacing on the canvas.",
  "semantics": {
    "element": "div"
  },
  "props": [
    {
      "name": "overflowLabel",
      "description": "The +N overflow indicator text.",
      "type": "text",
      "default": "+3",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Overflow"
        },
        "code": {
          "prop": "overflowLabel"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "inline-flex",
        "direction": "row",
        "align": "center"
      },
      "tokens": {
        "gap": "{space.gap.sm}"
      },
      "parts": {
        "stack": {
          "layout": {
            "direction": "row",
            "align": "center",
            "overlap": true
          },
          "tokens": {
            "gap": "{space.avatarGroup.overlap}"
          },
          "slot": {
            "name": "children",
            "accepts": [
              "ds.avatar"
            ],
            "acceptsMode": "prefer",
            "defaultContent": [
              {
                "id": "ds.avatar",
                "props": {
                  "size": "md"
                },
                "text": "AB"
              },
              {
                "id": "ds.avatar",
                "props": {
                  "size": "md"
                },
                "text": "CD"
              },
              {
                "id": "ds.avatar",
                "props": {
                  "size": "md"
                },
                "text": "EF"
              }
            ]
          }
        },
        "overflowText": {
          "element": "span",
          "content": {
            "prop": "overflowLabel"
          },
          "tokens": {
            "width": "{size.avatar.md}",
            "height": "{size.avatar.md}",
            "background-color": "{color.action.secondary.background}",
            "color": "{color.text.secondary}",
            "border-radius": "{radius.pill}",
            "font-family": "{font.control.family}",
            "font-size": "{font.avatar.size.md}",
            "font-weight": "{font.control.weight}"
          },
          "layout": {
            "display": "inline-flex",
            "direction": "row",
            "align": "center",
            "justify": "center"
          }
        }
      }
    }
  },
  "a11y": {
    "contrast": "AA"
  },
