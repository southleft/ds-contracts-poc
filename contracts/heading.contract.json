{
  "$schema": "./contract.schema.json",
  "id": "ds.heading",
  "name": "Heading",
  "version": "1.0.0",
  "status": "draft",
  "description": "Sectioning heading whose rendered HTML element follows the level prop (h1–h6) via semantics.elementByProp, with a visual size ramp on the existing control type scale — document outline and visual weight are deliberately independent axes. Text nodes carry no element semantics, so only code renders the element itself.",
  "semantics": {
    "element": "p",
    "elementByProp": {
      "prop": "level",
      "map": {
        "1": "h1",
        "2": "h2",
        "3": "h3",
        "4": "h4",
        "5": "h5",
        "6": "h6"
      }
    }
  },
  "props": [
    {
      "name": "level",
      "description": "Document outline level — drives the rendered element (h1–h6) and the size ramp.",
      "type": {
        "enum": ["1", "2", "3", "4", "5", "6"]
      },
      "default": "2",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Level",
          "values": {
            "1": "H1",
            "2": "H2",
            "3": "H3",
            "4": "H4",
            "5": "H5",
            "6": "H6"
          }
        },
        "code": {
          "prop": "level"
        }
      }
    },
    {
      "name": "size",
      "description": "Visual size on the control type scale — independent of the document outline level.",
      "type": {
        "enum": ["sm", "md", "lg"]
      },
      "default": "lg",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Size",
          "values": {
            "sm": "Small",
            "md": "Medium",
            "lg": "Large"
          }
        },
        "code": {
          "prop": "size"
        }
      }
    },
    {
      "name": "children",
      "description": "Heading text.",
      "type": "text",
      "default": "Heading",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Text"
        },
        "code": {
          "prop": "children"
        }
      }
    }
  ],
  "states": [],
  "anatomy": {
    "root": {
      "layout": {
        "display": "flex",
        "direction": "row",
