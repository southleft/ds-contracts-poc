{
  "$schema": "./contract.schema.json",
  "id": "ds.button",
  "name": "Button",
  "version": "1.3.0",
  "status": "draft",
  "description": "Triggers an action or event. Use one primary button per context.",
  "semantics": {
    "element": "button",
    "role": "button"
  },
  "props": [
    {
      "name": "variant",
      "description": "Visual prominence of the action.",
      "type": {
        "enum": [
          "primary",
          "secondary",
          "danger"
        ]
      },
      "default": "primary",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Variant",
          "values": {
            "primary": "Primary",
            "secondary": "Secondary",
            "danger": "Danger"
          }
        },
        "code": {
          "prop": "variant"
        }
      }
    },
    {
      "name": "size",
      "description": "Control density.",
      "type": {
        "enum": [
          "sm",
          "md",
          "lg"
        ]
      },
      "default": "md",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Size",
          "values": {
            "sm": "Small",
            "md": "Medium",
            "lg": "Large"
          }
        },
        "code": {
          "prop": "size"
        }
      }
    },
    {
      "name": "disabled",
      "description": "Prevents interaction and communicates unavailability.",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Disabled"
        },
        "code": {
          "prop": "disabled"
        }
      }
    },
    {
      "name": "loading",
      "description": "Shows a spinning busy indicator beside the label while an async action resolves.",
      "type": "boolean",
      "default": false,
      "bindings": {
        "figma": {
          "kind": "BOOLEAN",
          "property": "Loading"
        },
        "code": {
          "prop": "loading"
        }
      }
    },
    {
      "name": "children",
      "description": "Button label.",
      "type": "text",
      "default": "Button",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "children"
        }
      }
    }
  ],
  "states": [
    "hover",
    "focus-visible",
    "disabled"
  ],
  "anatomy": {
    "root": {
      "tokens": {
        "background-color": "{color.action.{variant}.background}",
        "color": "{color.action.{variant}.foreground}",
        "padding-inline": "{space.inset-x.{size}}",
        "padding-block": "{space.inset-y.{size}}",
        "border-radius": "{radius.control}",
        "gap": "{space.gap.control}",
        "font-family": "{font.control.family}",
        "font-weight": "{font.control.weight}",
        "font-size": "{font.control.size.{size}}"
      },
      "states": {
        "hover": {
          "background-color": "{color.action.{variant}.background-hover}"
        },
        "focus-visible": {
          "outline-color": "{color.border.focus}",
          "outline-width": "{border.width.focus}"
        },
        "disabled": {
          "opacity": "{opacity.disabled}"
        }
      },
      "layout": {
        "display": "inline-flex",
        "direction": "row",
        "align": "center",
        "justify": "center"
      },
      "parts": {
        "loadingSpinner": {
          "description": "Busy indicator, shown while loading.",
          "icon": {
            "asset": "spinner",
            "size": 14
          },
          "animation": "spin",
          "visibleWhen": {
            "prop": "loading"
          }
        },
        "label": {
          "element": "span",
          "content": {
            "prop": "children"
          }
        }
      }
    }
  },
  "a11y": {
    "focusVisible": true,
    "minHitArea": 44,
    "contrast": "AA"
  },
  "anchors": {
    "figma": {
      "fileKey": "8nim1d0IPnehMxA7B7SYxC",
      "componentSetKey": "1b5d2a573f3f39404af396bdbe944a30ca0eaec3",
      "nodeId": "5:21"
    },
    "code": {
      "importPath": "src/components/Button",
      "export": "Button"
    }
  }
}
