        "enum": [
          "section",
          "muted"
        ]
      },
      "default": "section",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "Variant",
          "values": {
            "section": "Section",
            "muted": "Muted"
          }
        },
        "code": {
          "prop": "variant"
        }
      }
    }
  ],
  "states": [],
