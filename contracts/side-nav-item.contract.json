{
  "$schema": "./contract.schema.json",
  "id": "ds.side-nav-item",
  "name": "SideNavItem",
  "version": "1.0.0",
  "status": "draft",
  "description": "A sidebar navigation row: icon, label, and trailing content, with a selected state. API mirrors industry convention (Astryx SideNavItem); nesting and collapse are behavior-layer boundaries.",
  "semantics": {
    "element": "a"
  },
  "props": [
    {
      "name": "state",
      "description": "Whether this item is the current page.",
      "type": {
        "enum": [
          "default",
          "selected"
        ]
      },
      "default": "default",
      "bindings": {
        "figma": {
          "kind": "VARIANT",
          "property": "State",
          "values": {
            "default": "Default",
            "selected": "Selected"
          }
        },
        "code": {
          "prop": "state"
        }
      }
    },
    {
      "name": "label",
      "description": "Item text.",
      "type": "text",
      "default": "Navigation item",
      "required": true,
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Label"
        },
        "code": {
          "prop": "label"
        }
      }
    },
    {
      "name": "href",
      "description": "Navigation target URL.",
      "type": "text",
      "default": "#",
      "bindings": {
        "figma": {
          "kind": "TEXT",
          "property": "Href"
        },
        "code": {
          "prop": "href"
        }
      }
    }
  ],
  "states": [
    "hover"
  ],
  "anatomy": {
    "root": {
      "layout": {
        "display": "flex",
        "direction": "row",
        "align": "center"
      },
      "attrs": {
        "href": "{href}"
      },
      "tokens": {
        "max-width": "{size.card.width}",
        "background-color": "{color.nav.{state}.background}",
        "color": "{color.nav.{state}.foreground}",
        "border-radius": "{radius.control}",
        "gap": "{space.gap.sm}",
        "padding-inline": "{space.inset-x.sm}",
        "padding-block": "{space.inset-y.md}",
        "font-family": "{font.control.family}",
        "font-size": "{font.control.size.sm}",
        "font-weight": "{font.control.weight}"
      },
      "states": {
        "hover": {
          "background-color": "{color.surface.sunken}"
        }
      },
      "parts": {
        "iconSlot": {
          "slot": {
            "name": "icon",
            "acceptsMode": "open"
          },
          "optional": true,
          "layout": {
            "direction": "row",
            "align": "center"
          }
        },
        "labelText": {
          "element": "span",
          "content": {
            "prop": "label"
          },
          "layout": {
            "grow": true
          }
        },
        "endContent": {
          "description": "Trailing badge or count.",
          "slot": {
            "name": "endContent",
            "accepts": [
              "ds.badge"
            ],
            "acceptsMode": "prefer"
          },
          "optional": true,
          "layout": {
            "direction": "row",
            "align": "center"
          }
        }
      }
    }
  },
  "a11y": {
    "contrast": "AA"
  },
  "anchors": {
    "figma": {
      "fileKey": "8nim1d0IPnehMxA7B7SYxC",
      "componentSetKey": "155b665997cadb6f418aa74bdd0ad9b00e348e97",
      "nodeId": "11:1016"
    },
    "code": {
      "importPath": "src/components/SideNavItem",
      "export": "SideNavItem"
    }
  }
}
